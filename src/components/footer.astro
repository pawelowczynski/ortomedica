    <!-- GDPR Cookie Banner -->
    <div id="cookie-banner" class="fixed bottom-0 md:bottom-6 left-0 md:left-6 md:max-w-[400px] w-full bg-white text-navy p-6 md:rounded-2xl shadow-[0_-10px_40px_rgba(0,0,0,0.1)] md:shadow-[0_10px_40px_rgba(0,0,0,0.12)] z-[100] hidden-banner pb-24 md:pb-6 border-t md:border border-gray-100">
        <div class="flex gap-4 items-start mb-5">
            <i data-lucide="cookie" class="w-6 h-6 text-gold shrink-0"></i>
            <div>
                <h4 class="font-bold text-sm mb-1 text-navy">Ciasteczka & RODO</h4>
                <p class="text-[11px] text-gray-500 font-light leading-relaxed">
                    Używamy plików cookie m.in. do poprawnego działania mapy Google. Klikając "Akceptuj" wyrażasz na to zgodę.
                </p>
            </div>
        </div>
        <div class="flex gap-3">
            <button id="accept-cookies" class="flex-1 bg-gold text-white py-3 rounded-xl text-xs font-bold uppercase tracking-wider hover:bg-navy transition-colors shadow-md hover:shadow-lg">Akceptuj</button>
            <a href="#" class="flex-1 text-center bg-gray-50 text-navy py-3 rounded-xl text-xs font-bold uppercase tracking-wider hover:bg-gray-200 transition-colors border border-gray-100">Polityka</a>
        </div>
    </div>

 <script>
        // 1. IMPORTUJEMY LUCIDE
        import { createIcons, icons } from 'lucide';

        // Inicjalizacja ikon Lucide
        createIcons({ icons });

        // 1. Zmiana wyglądu nawigacji przy scrollowaniu
        const nav = document.getElementById('main-nav');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
                nav.classList.remove('text-white', 'py-5');
                nav.classList.add('py-3');
            } else {
                nav.classList.remove('scrolled');
                nav.classList.add('text-white', 'py-5');
                nav.classList.remove('py-3');
            }
        });

        // 2. Mobile Menu Toggle
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        let isMenuOpen = false;

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;
            if (isMenuOpen) {
                mobileMenu.classList.remove('hidden');
                mobileMenu.classList.add('visible');
                // Change icon to X (używamy Lucide do podmiany)
                menuBtn.innerHTML = '<i data-lucide="x" class="w-8 h-8"></i>';
                createIcons(); // <--- Zmiana tutaj
            } else {
                mobileMenu.classList.remove('visible');
                mobileMenu.classList.add('hidden');
                menuBtn.innerHTML = '<i data-lucide="menu" class="w-8 h-8"></i>';
                createIcons(); // <--- Zmiana tutaj
            }
        }

        if (menuBtn) {
            menuBtn.addEventListener('click', toggleMenu);
        }
        
        if (mobileLinks) {
            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if(isMenuOpen) toggleMenu();
                });
            });
        }

        // 3. Efekt nasycenia kolorem zdjęcia lekarza (Intersection Observer)
        const observerOptions = { root: null, threshold: 0.5 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                }
            });
        }, observerOptions);

        const doctorImg = document.getElementById('doctor-img');
        if (doctorImg) observer.observe(doctorImg);

        // 4. Obsługa RODO (Cookie Banner) i Lazy Load Mapy Google
        const cookieBanner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('accept-cookies');
        const loadMapBtn = document.getElementById('load-map-btn');
        const mapContainer = document.getElementById('map-container');

        const MAP_IFRAME_HTML = `<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2489.349635741639!2d16.2007481!3d51.3907722!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470f1359c63c5d6f%3A0xc3c9f8016594270b!2sPawia%2067%2C%2059-300%20Lubin!5e0!3m2!1spl!2spl!4v1700000000000!5m2!1spl!2spl" class="w-full h-full border-0 absolute inset-0 rounded-[2rem]" allowfullscreen="" loading="lazy"></iframe>`;

        function checkCookies() {
            if (!localStorage.getItem('cookiesAccepted')) {
                // Pokaż banner po 1 sekundzie
                setTimeout(() => {
                    if(cookieBanner) cookieBanner.classList.remove('hidden-banner');
                }, 1000);
            } else {
                // Jeśli zaakceptowano wcześniej, od razu możemy załadować mapę jeśli użytkownik dopscrolluje
                setupMapObserver();
            }
        }

        function acceptCookies() {
            localStorage.setItem('cookiesAccepted', 'true');
            if(cookieBanner) cookieBanner.classList.add('hidden-banner');
            loadGoogleMap();
        }

        function loadGoogleMap() {
            if(mapContainer && !mapContainer.querySelector('iframe')) {
                mapContainer.innerHTML = MAP_IFRAME_HTML;
            }
        }

        // Akceptacja guzikiem w bannerze
        if(acceptBtn) acceptBtn.addEventListener('click', acceptCookies);
        
        // Wymuszenie wczytania mapy przyciskiem w placeholderze mapy
        if(loadMapBtn) {
            loadMapBtn.addEventListener('click', () => {
                acceptCookies(); // Akceptuje też ciasteczka
            });
        }

        // Observer do ładowania mapy jak jest w zasięgu wzroku (i są zgody)
        function setupMapObserver() {
            const mapObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && localStorage.getItem('cookiesAccepted')) {
                        loadGoogleMap();
                        mapObserver.disconnect();
                    }
                });
            });
            if (mapContainer) mapObserver.observe(mapContainer);
        }

        // Uruchomienie sprawdzania ciasteczek
        checkCookies();
  

        // 5. Interaktywny Suwak Metamorfoz (Before/After)
        const sliders = document.querySelectorAll('.ba-container');
        sliders.forEach(slider => {
            let isDown = false;
            const beforeLayer = slider.querySelector('.ba-before');
            const handle = slider.querySelector('.ba-slider-handle');

            const moveSlider = (e) => {
                if (!isDown) return;
                const rect = slider.getBoundingClientRect();
                let x = (e.clientX !== undefined ? e.clientX : e.touches[0].clientX) - rect.left;
                x = Math.max(0, Math.min(x, rect.width));
                const percent = (x / rect.width) * 100;
                beforeLayer.style.clipPath = `inset(0 ${100 - percent}% 0 0)`;
                handle.style.left = `${percent}%`;
            };

            const startSlide = (e) => {
                isDown = true;
                handle.style.transform = 'translate(-50%, -50%) scale(0.9)';
                moveSlider(e);
            };

            const endSlide = () => {
                isDown = false;
                handle.style.transform = 'translate(-50%, -50%) scale(1)';
            };

            slider.addEventListener('mousedown', startSlide);
            slider.addEventListener('touchstart', startSlide, {passive: true});
            
            window.addEventListener('mouseup', endSlide);
            window.addEventListener('touchend', endSlide);
            
            window.addEventListener('mousemove', (e) => { if(isDown) moveSlider(e); });
            window.addEventListener('touchmove', (e) => { if(isDown) moveSlider(e); }, {passive: true});
        });

        // 6. Powrót na górę (Back to top)
        const backToTopBtn = document.getElementById('back-to-top');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 500) {
                backToTopBtn.classList.add('visible');
            } else {
                backToTopBtn.classList.remove('visible');
            }
        });
        backToTopBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

      // 7. Walidacja formularza kontaktowego i Anti-spam Honeypot
        const contactForm = document.getElementById('contactForm');
        const formFeedback = document.getElementById('formFeedback');

        if(contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault();
                formFeedback.classList.remove('hidden', 'bg-red-50', 'text-red-600', 'border-red-200', 'bg-green-50', 'text-green-600', 'border-green-200', 'block');
                
                // Honeypot check
                const botCheck = document.getElementById('bot_check').value;
                if(botCheck) {
                    console.warn("Wykryto bota.");
                    return; 
                }

                // Native HTML5 validation check
                if (!contactForm.checkValidity()) {
                    formFeedback.innerHTML = "<i data-lucide='alert-circle' class='inline w-4 h-4 mr-1 mb-0.5'></i> Proszę poprawnie wypełnić wymagane pola (np. nr telefonu min. 9 cyfr).";
                    formFeedback.classList.add('block', 'bg-red-50', 'text-red-600', 'border-red-200');
                    createIcons({ icons }); // <--- POPRAWKA 1
                    return;
                }

                // Symulacja wysyłki
                const btn = contactForm.querySelector('button[type="submit"]');
                const originalText = btn.textContent;
                btn.innerHTML = "Wysyłanie...";
                btn.disabled = true;
                btn.classList.add('opacity-70');

                setTimeout(() => {
                    formFeedback.innerHTML = "<i data-lucide='check-circle' class='inline w-4 h-4 mr-1 mb-0.5'></i> Wiadomość została wysłana! Odezwiemy się niezwłocznie.";
                    formFeedback.classList.add('block', 'bg-green-50', 'text-green-600', 'border-green-200');
                    createIcons({ icons }); // <--- POPRAWKA 2
                    contactForm.reset();
                    
                    btn.textContent = originalText;
                    btn.disabled = false;
                    btn.classList.remove('opacity-70');
                }, 1500);
            });
        }
    </script>