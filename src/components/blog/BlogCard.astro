---
const { title, description, date, slug, tags = [], heroImage } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-white/5 border border-white/10 rounded-3xl p-6 md:p-7 hover:border-gold/60 hover:bg-white/10 transition-colors flex flex-col h-full">
  {heroImage && (
    <a href={`/blog/${slug}`} class="block mb-5 rounded-2xl overflow-hidden">
      <img
        src={heroImage}
        alt={title}
        loading="lazy"
        class="w-full h-48 md:h-56 object-cover transform hover:scale-[1.03] transition-transform duration-300"
      />
    </a>
  )}

  <div class="text-[11px] uppercase tracking-[0.35em] text-gold/80 mb-3">
    {formattedDate}
  </div>

  <h3 class="text-xl md:text-2xl serif text-white mb-3">
    <a href={`/blog/${slug}`} class="hover:text-gold transition-colors">
      {title}
    </a>
  </h3>

  <p class="text-sm text-white/70 leading-relaxed mb-4">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag: string) => (
        <span class="text-[10px] uppercase tracking-[0.25em] bg-white/5 border border-white/10 text-white/60 px-3 py-1 rounded-full">
          {tag.replace(/-/g, ' ')}
        </span>
      ))}
    </div>
  )}

  <div class="mt-auto pt-2">
    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.25em] text-gold hover:text-white transition-colors"
    >
      Czytaj artykuł
      <i data-lucide="arrow-right" class="w-4 h-4"></i>
    </a>
  </div>
</article>

