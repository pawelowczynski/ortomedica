---
const { title, description, date, slug, tags = [], heroImage } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('pl-PL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="flex h-full flex-col rounded-3xl border border-brand-steel/10 bg-white p-6 shadow-sm transition-colors hover:border-gold/40 hover:shadow-md md:p-7">
  {heroImage && (
    <a href={`/blog/${slug}`} class="mb-5 block overflow-hidden rounded-2xl">
      <img
        src={heroImage}
        alt={title}
        loading="lazy"
        class="h-48 w-full object-cover transition-transform duration-300 hover:scale-[1.03] md:h-56"
      />
    </a>
  )}

  <div class="mb-3 text-[11px] uppercase tracking-[0.35em] text-gold/90">
    {formattedDate}
  </div>

  <h3 class="serif mb-3 text-xl text-brand-steel md:text-2xl">
    <a href={`/blog/${slug}`} class="transition-colors hover:text-gold">
      {title}
    </a>
  </h3>

  <p class="mb-4 text-sm leading-relaxed text-brand-steel/70">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mb-4 flex flex-wrap gap-2">
      {tags.map((tag: string) => (
        <span class="rounded-full border border-brand-steel/10 bg-gray-soft px-3 py-1 text-[10px] uppercase tracking-[0.25em] text-brand-steel/60">
          {tag.replace(/-/g, ' ')}
        </span>
      ))}
    </div>
  )}

  <div class="mt-auto pt-2">
    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.25em] text-gold transition-colors hover:text-brand-steel"
    >
      Czytaj artykuł
      <i data-lucide="arrow-right" class="h-4 w-4"></i>
    </a>
  </div>
</article>
