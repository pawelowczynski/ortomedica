---
---

<section id="home" class="hero-bg relative flex min-h-[72vh] flex-col overflow-hidden pb-10 pt-20 md:min-h-[76vh] md:pb-0 md:pt-24">
  <div class="container relative z-10 mx-auto flex flex-1 flex-col justify-center px-6 pb-8 md:pb-10">
    <div class="max-w-3xl">
      <p class="mb-4 text-[10px] font-bold uppercase tracking-[0.35em] text-white drop-shadow-md md:text-xs md:tracking-[0.4em]">
        stomatologia · chirurgia · ortodoncja · Lubin
      </p>
      <h1 class="serif mb-5 text-3xl leading-[1.15] text-white drop-shadow-xl sm:text-4xl md:mb-6 md:text-5xl lg:text-6xl">
        Stomatologia dziecięca i ortodoncja w Lubinie
      </h1>
      <p class="mb-8 max-w-xl text-base font-light leading-relaxed text-white/90 drop-shadow-md md:text-lg">
        Leczymy bez stresu: wizyty adaptacyjne, spokojna atmosfera i pełna opieka nad zgryzem dziecka — także dla dorosłych, w jednym gabinecie.
      </p>
      <a
        href="#kontakt"
        class="btn-gold group inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-xs font-bold uppercase tracking-[0.18em] shadow-xl md:px-10 md:py-5 md:text-sm md:tracking-[0.2em]"
      >
        Umów konsultację
        <i data-lucide="calendar" class="h-4 w-4 transition-transform group-hover:scale-110"></i>
      </a>
    </div>
  </div>

  <div class="relative z-10 mt-auto hidden w-full shrink-0 bg-gradient-to-t from-surface-warm/95 via-surface-warm/40 to-transparent pt-8 pb-4 md:block">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-3 gap-6 border-t border-brand-steel/15 pt-6 md:gap-8">
        <div class="min-w-0 text-brand-steel">
          <p class="mb-1 text-2xl font-bold leading-tight text-brand-steel md:text-3xl">Lubin</p>
          <p class="text-[10px] uppercase leading-snug tracking-widest text-brand-steel/70 md:text-xs">Pawia 67 · ortodoncja</p>
        </div>
        <div class="min-w-0 border-l border-brand-steel/15 pl-4 text-brand-steel md:pl-8">
          <p class="mb-1 text-2xl font-bold leading-tight text-brand-steel md:text-3xl">iTero</p>
          <p class="text-[10px] uppercase leading-snug tracking-widest text-brand-steel/70 md:text-xs">Skan 3D · plan cyfrowy</p>
        </div>
        <div class="min-w-0 border-l border-brand-steel/15 pl-4 text-brand-steel md:pl-8">
          <p class="mb-1 text-2xl font-bold leading-tight text-brand-steel md:text-3xl">Invisalign</p>
          <p class="text-[10px] uppercase leading-snug tracking-widest text-brand-steel/70 md:text-xs">Nakładki · kwalifikacja</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="border-t border-brand-steel/10 bg-surface-warm py-6 md:hidden">
  <div class="container mx-auto flex max-w-lg justify-between gap-2 px-6 text-center">
    <div class="min-w-0 flex-1">
      <p class="mb-0.5 text-lg font-bold leading-tight text-brand-steel">Lubin</p>
      <p class="text-[9px] uppercase leading-tight tracking-wider text-brand-steel/70">Pawia 67 · ortodoncja</p>
    </div>
    <div class="min-w-0 flex-1 border-l border-brand-steel/15">
      <p class="mb-0.5 text-lg font-bold leading-tight text-brand-steel">iTero</p>
      <p class="text-[9px] uppercase leading-tight tracking-wider text-brand-steel/70">Skan 3D · plan cyfrowy</p>
    </div>
    <div class="min-w-0 flex-1 border-l border-brand-steel/15">
      <p class="mb-0.5 text-lg font-bold leading-tight text-brand-steel">Invisalign</p>
      <p class="text-[9px] uppercase leading-tight tracking-wider text-brand-steel/70">Nakładki · kwalifikacja</p>
    </div>
  </div>
</section>
