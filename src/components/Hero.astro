---
---

<section id="home" class="min-h-[72vh] md:min-h-[76vh] hero-bg relative flex flex-col overflow-hidden pt-20 md:pt-24 pb-10 md:pb-0">
  <div class="container relative z-10 mx-auto flex flex-1 flex-col justify-center px-6 pb-8 md:pb-10">
    <div class="max-w-3xl">
      <p class="mb-4 text-[10px] font-bold uppercase tracking-[0.35em] text-white drop-shadow-md md:text-xs md:tracking-[0.4em]">
        stomatologia dziecięca · chirurgia · ortodoncja · Lubin
      </p>
      <h1 class="serif mb-5 text-3xl leading-[1.15] text-white drop-shadow-xl sm:text-4xl md:mb-6 md:text-5xl lg:text-6xl">
        Przyjazna stomatologia dziecięca i ortodoncja w Lubinie
      </h1>
      <p class="mb-8 max-w-xl text-base font-light leading-relaxed text-white/90 drop-shadow-md md:text-lg">
        Leczymy bez stresu: wizyty adaptacyjne, spokojna atmosfera i pełna opieka nad zgryzem dziecka — także dla dorosłych, w jednym gabinecie.
      </p>
      <a
        href="#kontakt"
        class="btn-gold group inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-xs font-bold uppercase tracking-[0.18em] shadow-xl md:px-10 md:py-5 md:text-sm md:tracking-[0.2em]"
      >
        Umów konsultację
        <i data-lucide="calendar" class="h-4 w-4 transition-transform group-hover:scale-110"></i>
      </a>
    </div>
  </div>

  <div class="relative z-10 mt-auto hidden w-full shrink-0 bg-gradient-to-t from-[#0a192f] to-transparent pt-8 pb-4 md:block">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-3 gap-8 border-t border-white/20 pt-6">
        <div class="text-white">
          <p class="text-3xl font-bold text-gold mb-1">Dzieci</p>
          <p class="text-xs uppercase tracking-widest opacity-80">Priorytet w opiece</p>
        </div>
        <div class="text-white border-l border-white/20 pl-8">
          <p class="text-3xl font-bold text-gold mb-1">2500+</p>
          <p class="text-xs uppercase tracking-widest opacity-80">Pacjentów</p>
        </div>
        <div class="text-white border-l border-white/20 pl-8">
          <p class="text-3xl font-bold text-gold mb-1">5,0</p>
          <p class="text-xs uppercase tracking-widest opacity-80">Średnia w Google</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-navy py-6 md:hidden">
  <div class="container mx-auto px-6 flex justify-around text-center">
    <div>
      <p class="text-2xl font-bold text-gold mb-1">Dzieci</p>
      <p class="text-[10px] uppercase tracking-widest text-white/80">W centrum uwagi</p>
    </div>
    <div>
      <p class="text-2xl font-bold text-gold mb-1">2500+</p>
      <p class="text-[10px] uppercase tracking-widest text-white/80">Pacjentów</p>
    </div>
    <div>
      <p class="text-2xl font-bold text-gold mb-1">5,0</p>
      <p class="text-[10px] uppercase tracking-widest text-white/80">Średnia Google</p>
    </div>
  </div>
</section>
