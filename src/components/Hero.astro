---
---

<section id="home" class="min-h-[72vh] md:min-h-[76vh] hero-bg relative flex flex-col overflow-hidden pt-20 md:pt-24 pb-10 md:pb-0">
  <div class="container relative z-10 mx-auto flex flex-1 flex-col justify-center px-6 pb-8 md:pb-10">
    <div class="max-w-3xl">
      <p class="mb-4 text-[10px] font-bold uppercase tracking-[0.35em] text-white drop-shadow-md md:text-xs md:tracking-[0.4em]">
        stomatologia · chirurgia · ortodoncja · Lubin
      </p>
      <h1 class="serif mb-5 text-3xl leading-[1.15] text-white drop-shadow-xl sm:text-4xl md:mb-6 md:text-5xl lg:text-6xl">
        Stomatologia dziecięca i ortodoncja w Lubinie
      </h1>
      <p class="mb-8 max-w-xl text-base font-light leading-relaxed text-white/90 drop-shadow-md md:text-lg">
        Leczymy bez stresu: wizyty adaptacyjne, spokojna atmosfera i pełna opieka nad zgryzem dziecka — także dla dorosłych, w jednym gabinecie.
      </p>
      <a
        href="#kontakt"
        class="btn-gold group inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-xs font-bold uppercase tracking-[0.18em] shadow-xl md:px-10 md:py-5 md:text-sm md:tracking-[0.2em]"
      >
        Umów konsultację
        <i data-lucide="calendar" class="h-4 w-4 transition-transform group-hover:scale-110"></i>
      </a>
    </div>
  </div>

  <div class="relative z-10 mt-auto hidden w-full shrink-0 bg-gradient-to-t from-[#1A3A79] to-transparent pt-8 pb-4 md:block">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-3 gap-6 md:gap-8 border-t border-white/20 pt-6">
        <div class="text-white min-w-0">
          <p class="text-2xl md:text-3xl font-bold text-brand-blue mb-1 leading-tight">Lubin</p>
          <p class="text-[10px] md:text-xs uppercase tracking-widest opacity-80 leading-snug">Pawia 67 · ortodoncja</p>
        </div>
        <div class="text-white border-l border-white/20 pl-4 md:pl-8 min-w-0">
          <p class="text-2xl md:text-3xl font-bold text-brand-blue mb-1 leading-tight">iTero</p>
          <p class="text-[10px] md:text-xs uppercase tracking-widest opacity-80 leading-snug">Skan 3D · plan cyfrowy</p>
        </div>
        <div class="text-white border-l border-white/20 pl-4 md:pl-8 min-w-0">
          <p class="text-2xl md:text-3xl font-bold text-brand-blue mb-1 leading-tight">Invisalign</p>
          <p class="text-[10px] md:text-xs uppercase tracking-widest opacity-80 leading-snug">Nakładki · kwalifikacja</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-brand-steel py-6 md:hidden">
  <div class="container max-w-lg mx-auto px-4 flex justify-between gap-2 text-center">
    <div class="min-w-0 flex-1">
      <p class="text-lg font-bold text-gold mb-0.5 leading-tight">Lubin</p>
      <p class="text-[9px] uppercase tracking-wider text-white/80 leading-tight">Pawia 67</p>
    </div>
    <div class="min-w-0 flex-1 border-l border-white/20">
      <p class="text-lg font-bold text-gold mb-0.5 leading-tight">iTero</p>
      <p class="text-[9px] uppercase tracking-wider text-white/80 leading-tight">Skan 3D</p>
    </div>
    <div class="min-w-0 flex-1 border-l border-white/20">
      <p class="text-lg font-bold text-gold mb-0.5 leading-tight">Invisalign</p>
      <p class="text-[9px] uppercase tracking-wider text-white/80 leading-tight">Nakładki</p>
    </div>
  </div>
</section>
