---
import { homePageFaqs } from '../data/faq';

const faqs = homePageFaqs;
---

<section id="faq" class="py-14 md:py-18 bg-gray-50">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="text-center mb-8 md:mb-10">
      <h2 class="cinzel text-3xl md:text-4xl text-navy mb-4">Najczęstsze pytania</h2>
      <p class="text-[15px] text-gray-500 font-light">Zebraliśmy osiem kluczowych odpowiedzi, które najczęściej pomagają przed pierwszą wizytą.</p>
    </div>

    <div class="space-y-3">
      {
        faqs.map((item, idx) => (
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm transition-all">
            <summary class="flex items-center justify-between gap-4 px-5 md:px-6 py-5 cursor-pointer list-none">
              <h3 class="text-[15px] md:text-base font-semibold text-navy text-left">{idx + 1}. {item.q}</h3>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 md:px-6 pb-5 text-[15px] text-gray-600 leading-relaxed border-t border-gray-50">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>

    <div class="mt-8 text-center space-y-3">
      <p class="text-[13px] text-gray-500 font-light">Powyżej znajduje się pełna lista pytań z tej sekcji.</p>
      <a href="/blog" class="inline-flex items-center gap-2 text-navy hover:text-gold font-semibold transition-colors">
        Poradniki i artykuły na blogu
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>
