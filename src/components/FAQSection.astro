---
const faqs = [
  {
    q: 'Kiedy najlepiej zapisać dziecko na pierwszą wizytę ortodontyczną?',
    a: 'Najczęściej rekomendujemy konsultację około 7. roku życia. To dobry moment, aby ocenić rozwój zgryzu i zaplanować profilaktykę.'
  },
  {
    q: 'Czy przed leczeniem ortodontycznym potrzebna jest diagnostyka 3D?',
    a: 'W wielu przypadkach tak, bo pozwala precyzyjnie zaplanować terapię. Zakres diagnostyki dobieramy indywidualnie po badaniu.'
  },
  {
    q: 'Ile trwa leczenie aparatem stałym?',
    a: 'Najczęściej od 18 do 24 miesięcy, ale czas zależy od rodzaju wady zgryzu i systematyczności wizyt kontrolnych.'
  },
  {
    q: 'Czy Invisalign jest odpowiedni dla dorosłych pacjentów?',
    a: 'Tak, to częsty wybór dorosłych. Podczas konsultacji oceniamy, czy nakładki będą najlepszym rozwiązaniem w danym przypadku.'
  },
  {
    q: 'Czy leczenie ortodontyczne boli?',
    a: 'Zakładanie aparatu jest bezbolesne, natomiast po aktywacji może pojawić się krótkotrwała tkliwość zębów. To normalna reakcja.'
  },
  {
    q: 'Czy mogę płacić za leczenie w ratach?',
    a: 'Tak, dostępne są elastyczne opcje płatności. Szczegóły ustalamy podczas wizyty konsultacyjnej.'
  },
  {
    q: 'Jak dbać o higienę z aparatem?',
    a: 'Wymagana jest dokładna higiena po każdym posiłku oraz regularne wizyty higienizacyjne. Otrzymasz od nas praktyczne instrukcje.'
  },
  {
    q: 'Jak szybko mogę umówić pierwszy termin?',
    a: 'Zwykle pierwszą konsultację można zaplanować w ciągu kilku dni roboczych. W pilnych przypadkach szukamy najszybszego terminu.'
  }
];
---

<section id="faq" class="py-14 md:py-18 bg-gray-50">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="text-center mb-8 md:mb-10">
      <h2 class="cinzel text-3xl md:text-4xl text-navy mb-4">Najczęstsze pytania</h2>
      <p class="text-[15px] text-gray-500 font-light">Zebraliśmy osiem kluczowych odpowiedzi, które najczęściej pomagają przed pierwszą wizytą.</p>
    </div>

    <div class="space-y-3">
      {
        faqs.map((item, idx) => (
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm transition-all">
            <summary class="flex items-center justify-between gap-4 px-5 md:px-6 py-5 cursor-pointer list-none">
              <h3 class="text-[15px] md:text-base font-semibold text-navy text-left">{idx + 1}. {item.q}</h3>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 md:px-6 pb-5 text-[15px] text-gray-600 leading-relaxed border-t border-gray-50">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 text-navy hover:text-gold font-semibold transition-colors">
        Zobacz wszystkie pytania
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>
