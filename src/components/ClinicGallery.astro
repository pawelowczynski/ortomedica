---
---

<section id="klinika" class="py-14 md:py-18 bg-navy text-white relative border-t border-white/10">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-8 md:mb-10">
      <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Nasza przestrzeń</span>
      <h2 class="cinzel text-3xl md:text-4xl mb-4">Nowoczesna Klinika</h2>
      <p class="text-white/70 font-light text-sm max-w-2xl mx-auto">
        Zaprojektowana z myślą o Twoim komforcie i poczuciu bezpieczeństwa. Wyposażona w sprzęt diagnostyczny światowej klasy, eliminujący stres i ból.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <div class="overflow-hidden rounded-2xl group col-span-2 row-span-2 relative bg-navy-light">
        <img
          src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800"
          alt="Przestronna recepcja kliniki"
          loading="lazy"
          class="w-full h-full min-h-[300px] object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-4 py-2 rounded-lg text-[10px] uppercase tracking-widest font-bold border border-white/10"
        >
          Strefa relaksu
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl group relative bg-navy-light">
        <img
          src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=400"
          alt="Skaner 3D"
          loading="lazy"
          class="w-full h-48 md:h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-3 py-1.5 rounded-lg text-[9px] uppercase tracking-widest font-bold border border-white/10"
        >
          Diagnostyka 3D
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl group relative bg-navy-light">
        <img
          src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=400"
          alt="Nowoczesny fotel"
          loading="lazy"
          class="w-full h-48 md:h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-3 py-1.5 rounded-lg text-[9px] uppercase tracking-widest font-bold border border-white/10"
        >
          Gabinety
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl group col-span-2 relative bg-navy-light">
        <img
          src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800"
          alt="Zespół kliniki"
          loading="lazy"
          class="w-full h-48 md:h-64 object-cover transition-transform duration-700 group-hover:scale-105 object-top"
        />
        <div
          class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-4 py-2 rounded-lg text-[10px] uppercase tracking-widest font-bold border border-white/10"
        >
          Opieka asystentek
        </div>
      </div>
    </div>
  </div>
</section>

