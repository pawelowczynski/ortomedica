---
---

<section id="gabinet" class="relative border-t border-brand-steel/10 bg-surface-soft py-14 text-brand-steel md:py-18">
  <div class="container mx-auto px-6">
    <div class="mx-auto mb-8 max-w-3xl text-center md:mb-10">
      <span class="mb-4 block text-[10px] font-bold uppercase tracking-[0.3em] text-gold">Nasza przestrzeń</span>
      <h2 class="cinzel mb-4 text-3xl md:text-4xl">Gabinet w Lubinie</h2>
      <p class="mx-auto max-w-2xl text-sm font-light text-brand-steel/70">
        Zdjęcia poniżej mają charakter ilustracyjny (stock). Po wymianie na autorskie materiały z Lubina zaktualizuj opisy alternatywne (alt).
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
      <div class="group relative col-span-2 row-span-2 overflow-hidden rounded-2xl bg-white shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800"
          alt="Ilustracja: przestronna recepcja w gabinecie stomatologicznym"
          loading="lazy"
          class="h-full min-h-[300px] w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 rounded-lg border border-brand-steel/10 bg-white/90 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-brand-steel shadow-sm backdrop-blur"
        >
          Strefa relaksu
        </div>
      </div>
      <div class="group relative overflow-hidden rounded-2xl bg-white shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=400"
          alt="Ilustracja: stanowisko diagnostyczne"
          loading="lazy"
          class="h-48 w-full object-cover transition-transform duration-700 group-hover:scale-105 md:h-full"
        />
        <div
          class="absolute bottom-4 left-4 rounded-lg border border-brand-steel/10 bg-white/90 px-3 py-1.5 text-[9px] font-bold uppercase tracking-widest text-brand-steel shadow-sm backdrop-blur"
        >
          Diagnostyka 3D
        </div>
      </div>
      <div class="group relative overflow-hidden rounded-2xl bg-white shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=400"
          alt="Ilustracja: fotel stomatologiczny"
          loading="lazy"
          class="h-48 w-full object-cover transition-transform duration-700 group-hover:scale-105 md:h-full"
        />
        <div
          class="absolute bottom-4 left-4 rounded-lg border border-brand-steel/10 bg-white/90 px-3 py-1.5 text-[9px] font-bold uppercase tracking-widest text-brand-steel shadow-sm backdrop-blur"
        >
          Gabinety
        </div>
      </div>
      <div class="group relative col-span-2 overflow-hidden rounded-2xl bg-white shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800"
          alt="Ilustracja: zespół w placówce medycznej"
          loading="lazy"
          class="h-48 w-full object-cover object-top transition-transform duration-700 group-hover:scale-105 md:h-64"
        />
        <div
          class="absolute bottom-4 left-4 rounded-lg border border-brand-steel/10 bg-white/90 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-brand-steel shadow-sm backdrop-blur"
        >
          Opieka asystentek
        </div>
      </div>
    </div>
  </div>
</section>
