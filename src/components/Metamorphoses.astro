---
import { METAMORPHOSIS_FEATURED as item } from '../data/metamorphoses';
---

<section id="metamorfozy" class="py-14 md:py-18 bg-gray-soft">
  <div class="container mx-auto px-6">
    <div class="mb-8 max-w-xl md:mb-10">
      <span class="mb-4 block text-[10px] font-bold uppercase tracking-[0.3em] text-gold">Galeria uśmiechów</span>
      <h2 class="cinzel text-3xl text-navy md:text-4xl">Metamorfozy pacjentów</h2>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="group overflow-hidden rounded-[2rem] bg-gray-50 border border-gray-100 shadow-sm transition-all flex flex-col hover:shadow-xl">
        <div class="relative w-full h-64 md:h-80 ba-container cursor-ew-resize select-none overflow-hidden rounded-t-[2rem]">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <span
              class="ba-label ba-label-po absolute top-4 right-4 rounded-lg border border-brand-gold/40 px-4 py-2 text-xs font-bold uppercase tracking-widest shadow-lg"
            >
              Po
            </span>
            <img
              src={item.imgAfter}
              alt={item.altAfter}
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 768px, 100vw"
              class="w-full h-full object-cover object-center block"
            />
          </div>
          <div class="ba-before absolute inset-0 z-20 pointer-events-none" style="clip-path: inset(0 50% 0 0);">
            <span
              class="ba-label ba-label-przed absolute top-4 left-4 rounded-lg border border-brand-steel/20 px-4 py-2 text-xs font-bold uppercase tracking-widest shadow-lg"
            >
              Przed
            </span>
            <img
              src={item.imgBefore}
              alt={item.altBefore}
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 768px, 100vw"
              class="w-full h-full object-cover object-center block"
            />
            <div class="absolute top-0 right-0 w-0.5 h-full bg-gold"></div>
          </div>
          <div
            class="ba-slider-handle absolute top-1/2 left-1/2 z-30 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-2 border-gold bg-white shadow-xl pointer-events-none transition-transform duration-200"
          >
            <i data-lucide="arrow-right-left" class="h-4 w-4 text-gold"></i>
          </div>
        </div>
        <div class="border-t border-gray-100 bg-white px-3 py-2 md:px-4">
          <p class="text-[9px] font-light leading-snug text-gray-400 md:text-[10px] md:leading-relaxed">
            Przesuń suwak, aby zobaczyć efekt leczenia dokumentowany u pacjenta ORTHOMEDICA (zgoda na publikację). Kolejne case study dodajemy wyłącznie po uzyskaniu zgód.
          </p>
          <p class="mt-1.5 text-[9px] font-light leading-snug text-gray-400 md:text-[10px] md:leading-relaxed">
            Efekt jest indywidualny i nie stanowi gwarancji u innych osób —
            <a
              href="/informacje-dla-pacjentow#informacja-o-wyrobach-medycznych"
              class="text-gray-500 underline underline-offset-2 hover:text-gold"
              >ujawnienia (wyroby medyczne)</a
            >.
          </p>
        </div>
        <div class="grow bg-white p-8">
          <h3 class="cinzel text-lg md:text-xl mb-3 text-navy">{item.title}</h3>
          <div class="flex flex-wrap gap-4 mb-3">
            {item.tags.map((tag) => (
              <span
                class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-gold bg-gold/10 px-2 py-1 rounded"
              >
                <i data-lucide="tag" class="w-3 h-3"></i>
                {tag}
              </span>
            ))}
          </div>
          <p class="text-[15px] text-gray-500 font-light mb-6">Czas leczenia: {item.duration}.</p>
          <a
            href={item.articlePath}
            class="inline-flex items-center gap-2 text-sm font-semibold text-navy hover:text-gold transition-colors border-b border-navy/20 hover:border-gold pb-0.5"
          >
            Czytaj więcej — pełny opis leczenia
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center max-w-2xl mx-auto">
      <p class="text-navy font-light text-[17px] md:text-lg mb-6">Umów konsultację i poznaj możliwe ścieżki leczenia w gabinecie.</p>
      <a href="#kontakt" class="btn-gold px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider inline-flex items-center gap-2">
        Zrób pierwszy krok
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>
