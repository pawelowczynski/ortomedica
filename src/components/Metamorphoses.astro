---
---

<section id="metamorfozy" class="py-24 md:py-32 bg-[#f8f7f4]">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-xl">
        <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Galeria uśmiechów</span>
        <h2 class="cinzel text-3xl md:text-4xl text-navy">Metamorfozy pacjentów</h2>
      </div>
      <p class="text-[14px] md:text-[15px] text-gray-500 font-light italic md:text-right max-w-sm">
        Przesuń suwak, aby zobaczyć autentyczne efekty leczenia w naszej klinice.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Przykład 1 -->
      <div class="group overflow-hidden rounded-[2rem] bg-gray-50 border border-gray-100 shadow-sm transition-all flex flex-col hover:shadow-xl">
        <div class="relative w-full h-64 md:h-80 ba-container cursor-ew-resize select-none overflow-hidden rounded-t-[2rem]">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <span
              class="ba-label ba-label-po absolute top-4 right-4 bg-gold text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-widest shadow-lg border border-gold/20"
            >
              Po
            </span>
            <img
              src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=600"
              alt="Po leczeniu"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="w-full h-full object-cover block"
            />
          </div>
          <div class="ba-before absolute inset-0 z-20 pointer-events-none" style="clip-path: inset(0 50% 0 0);">
            <span
              class="ba-label ba-label-przed absolute top-4 left-4 bg-navy text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-widest shadow-lg border border-white/20"
            >
              Przed
            </span>
            <img
              src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=600"
              alt="Przed leczeniem"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="w-full h-full object-cover block"
            />
            <div class="absolute top-0 right-0 w-0.5 h-full bg-gold"></div>
          </div>
          <div
            class="ba-slider-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 w-10 h-10 bg-white border-2 border-gold rounded-full flex items-center justify-center shadow-xl pointer-events-none transition-transform duration-200"
          >
            <i data-lucide="arrow-right-left" class="w-4 h-4 text-gold"></i>
          </div>
        </div>
        <div class="p-8 grow bg-white">
          <h4 class="cinzel text-lg md:text-xl mb-3 text-navy">Korekta głębokiego zgryzu i stłoczeń</h4>
          <div class="flex gap-4 mb-2">
            <span
              class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-gold bg-gold/10 px-2 py-1 rounded"
            >
              <i data-lucide="tag" class="w-3 h-3"></i>
              Invisalign
            </span>
          </div>
          <p class="text-[15px] text-gray-500 font-light">Czas leczenia: 14 miesięcy.</p>
        </div>
      </div>

      <!-- Przykład 2 -->
      <div class="group overflow-hidden rounded-[2rem] bg-gray-50 border border-gray-100 shadow-sm transition-all flex flex-col hover:shadow-xl">
        <div class="relative w-full h-64 md:h-80 ba-container cursor-ew-resize select-none overflow-hidden rounded-t-[2rem]">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <span
              class="ba-label ba-label-po absolute top-4 right-4 bg-gold text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-widest shadow-lg border border-gold/20"
            >
              Po
            </span>
            <img
              src="https://images.unsplash.com/photo-1522845015757-50bce044e5da?auto=format&fit=crop&q=80&w=600"
              alt="Po leczeniu"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="w-full h-full object-cover block"
            />
          </div>
          <div class="ba-before absolute inset-0 z-20 pointer-events-none" style="clip-path: inset(0 50% 0 0);">
            <span
              class="ba-label ba-label-przed absolute top-4 left-4 bg-navy text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-widest shadow-lg border border-white/20"
            >
              Przed
            </span>
            <img
              src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=600"
              alt="Przed leczeniem"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="w-full h-full object-cover block"
            />
            <div class="absolute top-0 right-0 w-0.5 h-full bg-gold"></div>
          </div>
          <div
            class="ba-slider-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 w-10 h-10 bg-white border-2 border-gold rounded-full flex items-center justify-center shadow-xl pointer-events-none transition-transform duration-200"
          >
            <i data-lucide="arrow-right-left" class="w-4 h-4 text-gold"></i>
          </div>
        </div>
        <div class="p-8 grow bg-white">
          <h4 class="cinzel text-lg md:text-xl mb-3 text-navy">Zamknięcie diastemy i wyrównanie</h4>
          <div class="flex gap-4 mb-2">
            <span
              class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-navy bg-navy/10 px-2 py-1 rounded"
            >
              <i data-lucide="tag" class="w-3 h-3"></i>
              Aparat Stały
            </span>
          </div>
          <p class="text-[15px] text-gray-500 font-light">Czas leczenia: 18 miesięcy.</p>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center max-w-2xl mx-auto">
      <p class="text-navy font-light text-[17px] md:text-lg mb-6">Pozwól nam zadbać o Twój uśmiech.</p>
      <a href="#kontakt" class="btn-gold px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider inline-flex items-center gap-2">
        Zrób pierwszy krok
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>

