<section id="opinie" class="py-14 md:py-18 bg-gray-50 border-y border-gray-100">
  <div class="container mx-auto px-6">
    <div class="text-center mb-8 md:mb-10">
      <div class="flex justify-center gap-1 text-gold mb-4">
        <i data-lucide="star" class="fill-current w-6 h-6"></i>
        <i data-lucide="star" class="fill-current w-6 h-6"></i>
        <i data-lucide="star" class="fill-current w-6 h-6"></i>
        <i data-lucide="star" class="fill-current w-6 h-6"></i>
        <i data-lucide="star" class="fill-current w-6 h-6"></i>
      </div>
      <h2 class="cinzel text-3xl md:text-4xl text-navy mb-4">Opinie rodziców i pacjentów</h2>
      <p class="text-[15px] text-gray-500 font-light">Zobacz prawdziwe recenzje z Google i historie leczenia pacjentów.</p>
    </div>

    <div class="max-w-4xl mx-auto py-6 md:py-8">
      <div
        id="google-reviews-widget"
        class="bg-white min-h-[200px] md:min-h-[240px] rounded-3xl border border-gray-100 shadow-sm flex items-center justify-center px-6 text-center"
      >
        <div>
          <p class="text-navy font-semibold mb-2">Miejsce na widżet Google Reviews</p>
          <p class="text-sm text-gray-500">Tu zostanie osadzona dynamiczna lista aktualnych opinii pacjentów.</p>
        </div>
      </div>
    </div>
    <div class="mt-8 text-center">
      <a
        href="#kontakt"
        class="btn-gold inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full font-bold text-xs uppercase tracking-wider"
      >
        Umów wizytę dla dziecka
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>

