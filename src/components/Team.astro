---
---

<section id="o-mnie" class="py-24 md:py-28 bg-[#f8f7f4] border-b border-gray-100">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Zespół</span>
      <h2 class="cinzel text-3xl md:text-4xl text-navy mb-4">Lekarze ORTHOMEDICA</h2>
      <p class="text-[15px] md:text-base text-gray-500 font-light">
        Stomatologia dziecięca, chirurgia, endodoncja i ortodoncja — jeden zespół, żeby mali i dorośli pacjenci byli w dobrych rękach na każdym etapie leczenia.
      </p>
    </div>

    <!-- Kornelia wyróżniona (lekko większa karta) -->
    <div class="max-w-4xl mx-auto mb-10">
      <article class="bg-gray-50 rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col md:flex-row md:items-stretch">
        <div class="md:w-1/3">
          <img
            src="https://www.orthoclinic.com.pl/images/o-nas/nasz-zespol/kornelia-rumin-big.jpg"
            alt="Dr n. med. Kornelia Rumin"
            loading="lazy"
            class="w-full h-full aspect-[4/5] md:aspect-[3/4] object-cover object-center"
          />
        </div>
        <div class="p-6 md:p-8 flex flex-col flex-1">
          <h3 class="cinzel text-xl md:text-2xl text-navy mb-1">Dr n. med. Kornelia Rumin</h3>
          <p class="text-xs uppercase tracking-[0.2em] text-gold mb-3">Specjalista ortodonta</p>
          <p class="text-[15px] md:text-base text-gray-600 font-light mb-4 flex-1">
            Główna lekarka odpowiedzialna za plan leczenia w Orthomedica. Łączy doświadczenie naukowe z praktyką kliniczną, prowadząc kompleksowe leczenie ortodontyczne dzieci i dorosłych.
          </p>
          <a href="/dr-kornelia-rumin" class="inline-flex items-center gap-2 text-sm font-semibold text-gold hover:text-navy transition-colors mt-auto">
            Poznaj profil lekarza
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>
    </div>

    <!-- Lekarze (karty o zbliżonej wielkości) -->
    <div class="grid gap-6 md:gap-8 md:grid-cols-2 mb-12 max-w-5xl mx-auto">
      <!-- Lek. dent. Aleksandra Czerkawska -->
      <article class="bg-gray-50 rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col md:flex-row md:items-stretch">
        <div class="md:w-2/5">
          <img
            src="/lek-aleksandra-czerkawska.png"
            alt="Lek. dent. Aleksandra Czerkawska"
            loading="lazy"
            class="w-full h-full aspect-[4/5] md:aspect-[3/4] object-cover object-center"
          />
        </div>
        <div class="p-6 flex flex-col flex-1">
          <h3 class="cinzel text-lg md:text-xl text-navy mb-1">Lek. dent. Aleksandra Czerkawska</h3>
          <p class="text-xs uppercase tracking-[0.2em] text-gold mb-3">Stomatologia zachowawcza</p>
          <p class="text-[15px] md:text-base text-gray-600 font-light mb-4 flex-1">
            Dba o zdrowe, zadbane zęby przed, w trakcie i po leczeniu ortodontycznym — od profilaktyki po nowoczesne wypełnienia.
          </p>
          <a
            href="/lek-dent-aleksandra-czerkawska"
            class="inline-flex items-center gap-2 text-sm font-semibold text-gold hover:text-navy transition-colors mt-auto"
          >
            Poznaj profil lekarza
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>

      <!-- Lek. dent. Kamil Wojciechowski -->
      <article class="bg-gray-50 rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col md:flex-row md:items-stretch">
        <div class="md:w-2/5">
          <img
            src="/lek-kamil-wojciechowski.png"
            alt="Lek. dent. Kamil Wojciechowski"
            loading="lazy"
            class="w-full h-full aspect-[4/5] md:aspect-[3/4] object-cover object-center"
          />
        </div>
        <div class="p-6 flex flex-col flex-1">
          <h3 class="cinzel text-lg md:text-xl text-navy mb-1">Lek. dent. Kamil Wojciechowski</h3>
          <p class="text-xs uppercase tracking-[0.2em] text-gold mb-3">Endodoncja i chirurgia</p>
          <p class="text-sm text-gray-600 font-light mb-4 flex-1">
            Specjalizuje się w leczeniu kanałowym i zabiegach chirurgicznych, które przygotowują zęby do dalszego leczenia ortodontycznego.
          </p>
          <a
            href="/lek-dent-kamil-wojciechowski"
            class="inline-flex items-center gap-2 text-sm font-semibold text-gold hover:text-navy transition-colors mt-auto"
          >
            Poznaj profil lekarza
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>
    </div>

    <!-- Zespół administracyjny / wsparcie -->
    <div class="mt-6 md:mt-4">
      <div class="text-center mb-6">
        <h3 class="cinzel text-lg md:text-xl text-navy mb-2">Zespół recepcji i wsparcia pacjenta</h3>
        <p class="text-[15px] md:text-base text-gray-500 font-light">
          Pierwszy kontakt z kliniką i opiekę organizacyjną nad wizytami zapewniają osoby, które znają naszych pacjentów z imienia.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col items-center text-center p-4">
          <img src="/renata-rumin.png" alt="Renata Rumin" loading="lazy" class="w-28 h-28 rounded-full object-cover mb-3" />
          <h4 class="font-semibold text-navy text-sm mb-1">Renata Rumin</h4>
          <p class="text-[11px] uppercase tracking-[0.18em] text-gold mb-2">Recepcja / Koordynacja</p>
          <p class="text-[13px] text-gray-500">
            Pomaga zaplanować wizyty i czuwa nad harmonogramem leczenia.
          </p>
        </article>
        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col items-center text-center p-4">
          <img src="/sylwia-szych.png" alt="Sylwia Szych" loading="lazy" class="w-28 h-28 rounded-full object-cover mb-3" />
          <h4 class="font-semibold text-navy text-sm mb-1">Sylwia Szych</h4>
          <p class="text-[11px] uppercase tracking-[0.18em] text-gold mb-2">Asystentka</p>
          <p class="text-[13px] text-gray-500">
            Wspiera lekarzy przy fotelu i dba o komfort wizyty.
          </p>
        </article>
        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col items-center text-center p-4">
          <div class="w-28 h-28 rounded-full bg-gray-100 flex items-center justify-center mb-3">
            <span class="text-xs text-gray-400 uppercase tracking-[0.18em] leading-tight">
              ORTHO
              <br />
              TEAM
            </span>
          </div>
          <h4 class="font-semibold text-navy text-sm mb-1">Zespół wspierający</h4>
          <p class="text-[11px] uppercase tracking-[0.18em] text-gold mb-2">Rejestracja i asysty</p>
          <p class="text-[13px] text-gray-500">
            Pozostali członkowie zespołu, którzy współtworzą atmosferę kliniki.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>

