---
---

<section id="pierwsza-wizyta" class="py-24 bg-navy text-white relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Krok po kroku</span>
      <h2 class="cinzel text-3xl md:text-4xl mb-4">Jak wygląda leczenie?</h2>
      <p class="text-white/70 font-light">Przejrzysty proces. Od diagnozy po wymarzony uśmiech.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="text-center relative">
        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10">
          <span class="cinzel text-3xl text-gold font-bold">1</span>
        </div>
        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Konsultacja</h4>
        <p class="text-sm text-white/60 font-light">Wywiad, badanie zgryzu i omówienie Twoich oczekiwań.</p>
      </div>
      <div class="text-center relative">
        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10">
          <span class="cinzel text-3xl text-gold font-bold">2</span>
        </div>
        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Diagnostyka 3D</h4>
        <p class="text-sm text-white/60 font-light">Cyfrowy skan iTero, zdjęcia RTG oraz fotografie twarzy.</p>
      </div>
      <div class="text-center relative">
        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10">
          <span class="cinzel text-3xl text-gold font-bold">3</span>
        </div>
        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Plan Leczenia</h4>
        <p class="text-sm text-white/60 font-light">Omówienie symulacji wyników, kosztorysu i harmonogramu.</p>
      </div>
      <div class="text-center relative">
        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10">
          <span class="cinzel text-3xl text-gold font-bold">4</span>
        </div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Start</h4>
        <p class="text-sm text-white/60 font-light">Założenie aparatu lub wydanie pierwszych nakładek.</p>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a href="#kontakt" class="inline-block bg-gold hover:bg-white hover:text-navy text-white border border-gold px-8 py-4 rounded-full font-bold text-xs uppercase tracking-[0.2em] transition-all">
        Zrób pierwszy krok
      </a>
    </div>
  </div>
</section>

