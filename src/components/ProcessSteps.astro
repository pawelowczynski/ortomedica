---
---

<section id="pierwsza-wizyta" class="py-24 bg-navy text-white relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Jak to działa</span>
      <h2 class="cinzel text-3xl md:text-4xl mb-4">Ścieżki leczenia w ORTHOMEDICA</h2>
      <p class="text-[15px] md:text-base text-white/70 font-light">
        Najczęściej zaczynamy od stomatologii dziecięcej. Chirurgia, gnatologia i ortodoncja dołączają wtedy, gdy jest ku temu potrzeba.
      </p>
    </div>

    <div class="max-w-5xl mx-auto space-y-16">
      <div>
        <h3 class="cinzel text-lg text-gold mb-8 text-center md:text-left">1 · Stomatologia dziecięca</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">1</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Kontakt</h4>
            <p class="text-[15px] text-white/60 font-light">Rejestracja — wybierz termin pierwszej wizyty.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">2</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Wizyta adaptacyjna</h4>
            <p class="text-[15px] text-white/60 font-light">Oswajamy dziecko z gabinetem i zespołem.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">3</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Plan i leczenie</h4>
            <p class="text-[15px] text-white/60 font-light">Profilaktyka, wypełnienia — zgodnie z potrzebami.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">4</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Kontrole</h4>
            <p class="text-[15px] text-white/60 font-light">Regularne przeglądy i higiena.</p>
          </div>
        </div>
      </div>

      <div class="border-t border-white/10 pt-16">
        <h3 class="cinzel text-lg text-gold mb-8 text-center md:text-left">2 · Chirurgia i gnatologia</h3>
        <div class="grid md:grid-cols-2 gap-10 max-w-3xl mx-auto">
          <div class="text-center md:text-left">
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3 text-white/90">Chirurgia</h4>
            <p class="text-[15px] text-white/60 font-light">
              Ekstrakcje, zęby zatrzymane, zabiegi przygotowujące — po konsultacji i kwalifikacji.
            </p>
          </div>
          <div class="text-center md:text-left">
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3 text-white/90">Gnatologia</h4>
            <p class="text-[15px] text-white/60 font-light">
              Objawy ze strony stawów TMJ i mięśni żucia — konsultacja i plan terapii.
            </p>
          </div>
        </div>
      </div>

      <div class="border-t border-white/10 pt-16">
        <h3 class="cinzel text-lg text-gold mb-8 text-center md:text-left">3 · Ortodoncja (dzieci i młodzież)</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">1</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Konsultacja</h4>
            <p class="text-[15px] text-white/60 font-light">Ok. 7. r.ż. lub później — ocena zgryzu.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">2</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Diagnostyka 3D</h4>
            <p class="text-[15px] text-white/60 font-light">Skan iTero, dokumentacja, gdy potrzebna.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">3</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Plan</h4>
            <p class="text-[15px] text-white/60 font-light">Dobór metody: aparat, nakładki lub obserwacja.</p>
          </div>
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6">
              <span class="cinzel text-3xl text-gold font-bold">4</span>
            </div>
            <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Leczenie</h4>
            <p class="text-[15px] text-white/60 font-light">Realizacja i wizyty kontrolne.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a href="#kontakt" class="inline-block bg-gold hover:bg-white hover:text-navy text-white border border-gold px-8 py-4 rounded-full font-bold text-xs uppercase tracking-[0.2em] transition-all">
        Zapisz dziecko na wizytę
      </a>
    </div>
  </div>
</section>
