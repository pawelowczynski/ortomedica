---
const childLinks = [
  '/blog/ortodonta-dla-dziecka-kiedy-pierwsza-wizyta',
  '/blog/jak-przygotowac-dziecko-do-pierwszej-wizyty-u-dentysty',
  '/blog/zgrzytanie-zebami-u-dzieci-kiedy-do-specjalisty',
  '/blog/aparat-staly-jak-dbac-o-zeby',
];
const orthoLinks = [
  '/blog/czy-aparat-boli-pierwszy-tydzien-z-aparatem',
  '/zabiegi/skan-3d-shining',
  '/blog/higiena-zebow-z-aparatem-stalym-10-zasad',
  '/blog/retencja-po-aparacie-dlaczego-jest-konieczna',
];
const linkClass =
  'mt-3 inline-flex items-center gap-1 text-[11px] font-bold uppercase tracking-wider text-gold transition-colors hover:text-brand-steel';
---

<section id="jak-leczymy" class="relative overflow-hidden bg-surface-warm py-14 text-brand-steel md:py-18">
  <span id="pierwsza-wizyta" class="relative -top-28 block"></span>
  <div class="absolute top-0 right-0 h-96 w-96 translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-gold-light/25 blur-3xl"></div>
  <div class="container relative z-10 mx-auto px-6">
    <div class="mx-auto mb-8 max-w-2xl text-center md:mb-10">
      <span class="mb-4 block text-[10px] font-bold uppercase tracking-[0.3em] text-gold">Jak to działa</span>
      <h2 class="cinzel mb-4 text-3xl md:text-4xl">Ścieżka leczenia</h2>
      <p class="text-[15px] font-light text-brand-steel/75 md:text-base">
        Wybierz ścieżkę dopasowaną do wieku pacjenta i zobacz kolejne kroki leczenia.
      </p>
    </div>

    <div class="mx-auto max-w-5xl">
      <div class="rounded-3xl border border-brand-steel/10 bg-white p-4 shadow-sm md:p-6">
        <div class="mb-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <button
            type="button"
            class="process-tab-btn is-active w-full cursor-pointer rounded-xl border border-brand-gold bg-brand-gold px-5 py-4 text-sm font-bold uppercase tracking-wider text-white transition-all"
            data-target="dziecko"
            aria-controls="timeline-dziecko"
            aria-selected="true"
          >
            Pierwsza wizyta dziecka
          </button>
          <button
            type="button"
            class="process-tab-btn w-full cursor-pointer rounded-xl border border-gray-200 bg-white px-5 py-4 text-sm font-bold uppercase tracking-wider text-brand-steel transition-all"
            data-target="ortodoncja"
            aria-controls="timeline-ortodoncja"
            aria-selected="false"
          >
            Leczenie ortodontyczne
          </button>
        </div>

        <div id="timeline-dziecko" class="process-tab-content is-active">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">1</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Wywiad i adaptacja</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Spokojna rozmowa z rodzicem i dzieckiem oraz ocena nawyków jamy ustnej.</p>
              <a href={childLinks[0]} class={linkClass}>
                Poradnik
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">2</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Badanie i diagnoza</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Kontrola zgryzu i wskazanie, czy potrzebna jest profilaktyka, obserwacja albo leczenie.</p>
              <a href={childLinks[1]} class={linkClass}>
                Poradnik
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">3</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Plan dla rodzica</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Proste zalecenia domowe oraz harmonogram kolejnych wizyt kontrolnych.</p>
              <a href={childLinks[2]} class={linkClass}>
                Artykuł
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">4</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Dalsze prowadzenie</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Monitorowanie rozwoju uzębienia i szybka reakcja na ewentualne nieprawidłowości.</p>
              <a href={childLinks[3]} class={linkClass}>
                Blog
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
          </div>
        </div>

        <div id="timeline-ortodoncja" class="process-tab-content hidden">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">1</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Konsultacja</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Ocena wady zgryzu i omówienie oczekiwań oraz priorytetów leczenia.</p>
              <a href={orthoLinks[0]} class={linkClass}>
                Poradnik
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">2</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Diagnostyka</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Skan 3D, RTG, dokumentacja i analiza potrzebna do precyzyjnego planu terapii.</p>
              <a href={orthoLinks[1]} class={linkClass}>
                Skan 3D
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">3</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Plan leczenia</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Dobór metody: aparat stały lub inne rozwiązania wraz z harmonogramem wizyt.</p>
              <a href={orthoLinks[2]} class={linkClass}>
                Higiena z aparatem
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
            <article class="rounded-2xl border border-gray-100 bg-gray-soft/80 p-5">
              <div class="mb-2 flex items-baseline gap-3">
                <p class="cinzel text-2xl font-bold leading-none text-gold tabular-nums shrink-0">4</p>
                <h3 class="min-w-0 text-xs font-bold uppercase leading-snug tracking-widest">Kontrole i retencja</h3>
              </div>
              <p class="text-sm text-brand-steel/70">Regularne kontrole, finalizacja leczenia i utrzymanie osiągniętego efektu.</p>
              <a href={orthoLinks[3]} class={linkClass}>
                Retencja
                <i data-lucide="arrow-right" class="h-3.5 w-3.5"></i>
              </a>
            </article>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a href="#kontakt" class="btn-gold inline-flex items-center justify-center rounded-full px-8 py-4 text-xs font-bold uppercase tracking-[0.2em]">
        Umów wizytę
      </a>
    </div>
  </div>
</section>
