---
/**
 * Sekcja zarezerwowana pod przyszły cennik — obecnie pusty obszar (kotwica #cennik zachowana dla nawigacji).
 */
---

<section
  id="cennik"
  class="cennik-section py-16 md:py-24 bg-gray-50 border-y border-gray-100"
  aria-labelledby="cennik-heading"
>
  <div class="container mx-auto px-6 max-w-5xl">
    <h2 id="cennik-heading" class="sr-only">Cennik</h2>
    <div
      class="min-h-[14rem] md:min-h-[18rem] rounded-3xl border border-dashed border-gray-200 bg-white/40"
      aria-hidden="true"
    ></div>
  </div>
</section>
