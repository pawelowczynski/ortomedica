---
import { cennikTabs } from './cennik.data.js';

const defaultTabId =
  cennikTabs.find((tab) => tab.featured) !== undefined
    ? cennikTabs.find((tab) => tab.featured).id
    : cennikTabs[0].id;

const orthodonticOrder = [
  'ort-nakladki',
  'ort-aparat-staly',
  'ort-dzieci',
  'ort-diagnostyka',
  'ort-retencja',
];
---

<section
  id="cennik"
  class="cennik-section py-24 md:py-32 bg-gray-50"
  aria-labelledby="cennik-heading"
>
  <div class="container mx-auto px-6 max-w-5xl js-cennik-root">
    <header class="cennik-header opacity-0 translate-y-3">
      <div class="flex items-center justify-center gap-3 text-gray-400 text-[10px] tracking-[0.3em] uppercase mb-4">
        <div class="h-px w-10 bg-gray-300 hidden sm:block"></div>
        <span>Transparentne ceny</span>
        <div class="h-px w-10 bg-gray-300 hidden sm:block"></div>
      </div>
      <h2
        id="cennik-heading"
        class="cinzel text-3xl md:text-4xl text-navy text-center mb-4"
      >
        Cennik
      </h2>
      <p class="text-gray-500 font-light text-sm md:text-base text-center max-w-2xl mx-auto">
        Widełki cenowe są orientacyjne. Wiążący kosztorys wystawiamy bezpłatnie po
        konsultacji i diagnostyce — bez żadnych zobowiązań.
      </p>
    </header>

    <!-- Główne kategorie -->
    <div
      class="cennik-tabs-wrapper mt-10 md:mt-12 opacity-0 translate-y-3"
      role="tablist"
      aria-label="Grupy cennika"
    >
      <div class="cennik-tabs-scroll">
        {
          cennikTabs.map((tab, index) => (
            <button
              type="button"
              role="tab"
              id={`tab-${tab.id}`}
              class={`cennik-tab ${tab.id === defaultTabId ? 'is-active' : ''}`}
              aria-selected={tab.id === defaultTabId ? 'true' : 'false'}
              aria-controls={`panel-${tab.id}`}
              data-tab-id={tab.id}
              tabindex={tab.id === defaultTabId ? '0' : '-1'}
            >
              <span class="cennik-tab-icon" aria-hidden="true">
                {tab.icon}
              </span>
              <span class="cennik-tab-label">{tab.label}</span>
            </button>
          ))
        }
      </div>
    </div>

    <!-- Panelee kategorii -->
    <div class="mt-10 md:mt-12 space-y-10">
      {
        cennikTabs.map((tab, tabIndex) => (
          <section
            id={`panel-${tab.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${tab.id}`}
            class={`cennik-panel ${
              tab.id === defaultTabId ? 'is-active' : 'is-hidden'
            }`}
            data-panel-id={tab.id}
          >
            <div class="mb-6 md:mb-8">
              <p class="text-sm md:text-base text-gray-600 font-light max-w-3xl">
                {tab.intro}
              </p>
            </div>

            {/* Ortodoncja jako sekcje, bez wewnętrznych zakładek */}
            {
              tab.type === 'orthodontics' &&
                tab.subTabs && (
                  <div class="space-y-10">
                    {
                      orthodonticOrder.map((subId) => {
                        const sub = tab.subTabs?.find((s) => s.id === subId);
                        if (!sub) return null;

                        return (
                          <section>
                            <h3 class="cinzel text-lg md:text-xl text-navy mb-2">
                              {sub.label}
                            </h3>
                            {sub.intro && (
                              <p class="text-xs md:text-sm text-gray-600 font-light max-w-3xl mb-4">
                                {sub.intro}
                              </p>
                            )}

                            {sub.type === 'cards' && (
                              <div class="grid gap-4 md:gap-6 md:grid-cols-2 lg:grid-cols-3">
                                {
                                  sub.items.map((item, index) => (
                                    <article
                                      class="price-card bg-white rounded-2xl border border-gray-100 p-5 md:p-6 flex flex-col justify-between opacity-0 translate-y-3"
                                      data-card
                                      style={`transition-delay: ${
                                        220 + index * 60
                                      }ms;`}
                                    >
                                      <div>
                                        {item.tag && (
                                          <div class="mb-3">
                                            <span
                                              class={`inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wide ${
                                                item.tag === 'Najpopularniejszy'
                                                  ? 'bg-gold text-white'
                                                  : 'bg-amber-100 text-amber-800'
                                              }`}
                                            >
                                              {item.tag}
                                            </span>
                                          </div>
                                        )}
                                        <h3 class="text-sm md:text-base font-semibold text-navy mb-1">
                                          {item.name}
                                        </h3>
                                        {item.desc && (
                                          <p class="text-xs md:text-[13px] text-gray-500 mb-3">
                                            {item.desc}
                                          </p>
                                        )}
                                      </div>
                                      <div class="mt-2 pt-2 border-t border-gray-100 flex flex-col">
                                        <span class="text-base md:text-lg font-semibold text-gold leading-tight">
                                          {item.price}
                                        </span>
                                        {item.unit && (
                                          <span class="text-[11px] text-gray-500 mt-0.5">
                                            {item.unit}
                                          </span>
                                        )}
                                        {item.note && (
                                          <span class="mt-1 text-[11px] text-gray-400 leading-relaxed">
                                            {item.note}
                                          </span>
                                        )}
                                      </div>
                                    </article>
                                  ))
                                }
                              </div>
                            )}

                            {sub.infoBox && (
                              <div class="mt-6 md:mt-8">
                                <div class="cennik-infobox opacity-0 translate-y-3">
                                  <div class="flex items-start gap-3">
                                    <div class="mt-0.5 text-gold text-base" aria-hidden="true">
                                      💡
                                    </div>
                                    <div>
                                      <h3 class="text-sm font-semibold text-navy mb-1">
                                        {sub.infoBox.title}
                                      </h3>
                                      <p class="text-xs md:text-[13px] text-gray-500 leading-relaxed">
                                        {sub.infoBox.content}
                                      </p>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            )}

                            {sub.id === 'ort-nakladki' && (
                              <>
                                <blockquote class="mt-6 md:mt-8 border border-gray-100 rounded-2xl px-4 py-4 md:px-5 md:py-5 bg-white/60">
                                  <p class="text-xs md:text-[13px] text-gray-600 italic leading-relaxed mb-3">
                                    "Zdecydowałem się na nakładki, bo dużo pracuję z klientami. Praktycznie niewidoczne, zdejmuję do jedzenia. Cały proces skanowania to kosmos w porównaniu do masy, którą pamiętam z dzieciństwa."
                                  </p>
                                  <footer class="flex items-center gap-3 text-[11px] text-gray-500">
                                    <span class="text-amber-500 tracking-[0.2em] text-[10px]">
                                      ★★★★★
                                    </span>
                                    <span class="font-semibold text-gray-700">
                                      Michał K.
                                    </span>
                                    <span class="text-gray-400 text-[10px] uppercase tracking-[0.18em]">
                                      Google
                                    </span>
                                  </footer>
                                </blockquote>

                                <div class="mt-6 md:mt-8 flex flex-col md:flex-row md:items-center gap-3 md:gap-4">
                                  <a
                                    href="#kontakt"
                                    class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-gold text-white text-[11px] md:text-xs font-semibold tracking-[0.18em] uppercase shadow-md hover:bg-amber-500 transition-colors"
                                  >
                                    Umów bezpłatną konsultację →
                                  </a>
                                  <span class="text-[11px] text-gray-500">
                                    lub pobierz pełny cennik PDF poniżej
                                  </span>
                                </div>
                              </>
                            )}

                            {sub.id === 'ort-aparat-staly' && (
                              <div class="mt-6 md:mt-8 flex flex-col md:flex-row md:items-center gap-3 md:gap-4">
                                <a
                                  href="#kontakt"
                                  class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-gold text-white text-[11px] md:text-xs font-semibold tracking-[0.18em] uppercase shadow-md hover:bg-amber-500 transition-colors"
                                >
                                  Umów konsultację →
                                </a>
                                <span class="text-[11px] text-gray-500">
                                  Pełny plan kosztów przygotujemy na pierwszej wizycie.
                                </span>
                              </div>
                            )}
                          </section>
                        );
                      })
                    }
                  </div>
                )
            }

            <!-- Standardowe karty (pozostałe kategorie) -->
            {
              tab.type === 'cards' && (
                <div class="grid gap-4 md:gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {
                    tab.items.map((item, index) => (
                      <article
                        class={`price-card bg-white rounded-2xl border border-gray-100 p-5 md:p-6 flex flex-col justify-between opacity-0 translate-y-3`}
                        data-card
                        style={`transition-delay: ${
                          220 + index * 60
                        }ms;`}
                      >
                        <div>
                          {item.tag && (
                            <div class="mb-3">
                              <span
                                class={`inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wide ${
                                  item.tag === 'Najpopularniejszy'
                                    ? 'bg-gold text-white'
                                    : 'bg-amber-100 text-amber-800'
                                }`}
                              >
                                {item.tag}
                              </span>
                            </div>
                          )}
                          <h3 class="text-sm md:text-base font-semibold text-navy mb-1">
                            {item.name}
                          </h3>
                          {item.desc && (
                            <p class="text-xs md:text-[13px] text-gray-500 mb-3">
                              {item.desc}
                            </p>
                          )}
                        </div>
                        <div class="mt-2 pt-2 border-t border-gray-100 flex flex-col">
                          <span class="text-base md:text-lg font-semibold text-gold leading-tight">
                            {item.price}
                          </span>
                          {item.unit && (
                            <span class="text-[11px] text-gray-500 mt-0.5">
                              {item.unit}
                            </span>
                          )}
                          {item.note && (
                            <span class="mt-1 text-[11px] text-gray-400 leading-relaxed">
                              {item.note}
                            </span>
                          )}
                        </div>
                      </article>
                    ))
                  }
                </div>
              )
            }

            {tab.infoBox && (
              <div class="mt-6 md:mt-8">
                <div class="cennik-infobox opacity-0 translate-y-3">
                  <div class="flex items-start gap-3">
                    <div class="mt-0.5 text-gold text-base" aria-hidden="true">
                      💡
                    </div>
                    <div>
                      <h3 class="text-sm font-semibold text-navy mb-1">
                        {tab.infoBox.title}
                      </h3>
                      <p class="text-xs md:text-[13px] text-gray-500 leading-relaxed">
                        {tab.infoBox.content}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            )}

            {tab.type === 'groups' && tab.groups && (
              <div class="space-y-6">
                {
                  tab.groups.map((group) => (
                    <section class="bg-white rounded-2xl border border-gray-100 opacity-0 translate-y-3 px-5 md:px-6 py-4 md:py-5">
                      <h3 class="text-sm md:text-base font-semibold text-navy mb-3">
                        {group.groupName}
                      </h3>
                      <ul class="divide-y divide-gray-100">
                        {
                          group.items.map((item) => (
                            <li class="flex items-center justify-between gap-4 py-2.5">
                              <span class="text-xs md:text-[13px] text-gray-600">
                                {item.name}
                              </span>
                              <span
                                class={`text-xs md:text-sm font-semibold ${
                                  item.price === 'wycena indywidualna'
                                    ? 'text-gray-400 italic'
                                    : 'text-gold'
                                }`}
                              >
                                {item.price}
                              </span>
                            </li>
                          ))
                        }
                      </ul>
                    </section>
                  ))
                }
              </div>
            )}
          </section>
        ))
      }
    </div>

    <!-- CTA + disclaimer -->
    <div class="mt-12 md:mt-14 cta-wrapper opacity-0 translate-y-3">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 md:gap-6">
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-gold text-white text-xs md:text-sm font-semibold tracking-[0.18em] uppercase shadow-md hover:bg-amber-500 transition-colors"
        >
          Umów konsultację
        </a>
        <a
          href="/cennik.pdf"
          class="inline-flex items-center justify-center gap-2 text-xs md:text-sm text-gray-500 hover:text-navy transition-colors"
        >
          Pobierz pełny cennik PDF
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
      <p class="mt-6 text-[11px] text-gray-400 text-center max-w-2xl mx-auto leading-relaxed">
        Ceny mają charakter orientacyjny i mogą ulec zmianie. Wiążący kosztorys
        wystawiamy po badaniu i analizie diagnostycznej. Oferujemy możliwość
        płatności w ratach — zapytaj o szczegóły podczas konsultacji.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#cennik');
    if (!section) return;

    const root = section.querySelector('.js-cennik-root');
    if (!root) return;

    const prefersReduced =
      window.matchMedia &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const header = root.querySelector('.cennik-header');
    const tabsWrapper = root.querySelector('.cennik-tabs-wrapper');
    const panels = root.querySelectorAll('.cennik-panel');
    const cards = root.querySelectorAll('[data-card]');
    const highlight = root.querySelector('.price-card-highlight');
    const infoBoxes = root.querySelectorAll('.cennik-infobox');
    const accordions = root.querySelectorAll('.cennik-accordion');
    const ctaWrapper = root.querySelector('.cta-wrapper');

    const tabButtons = root.querySelectorAll('[role="tab"]');

    function setActiveTab(tabId) {
      tabButtons.forEach((btn) => {
        const isActive = btn.dataset.tabId === tabId;
        btn.classList.toggle('is-active', isActive);
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
        btn.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panelId === tabId;
        if (isActive) {
          panel.classList.remove('is-hidden');
          // restart animation
          if (!prefersReduced) {
            panel.classList.remove('panel-enter');
            // force reflow
            void panel.offsetWidth;
            panel.classList.add('panel-enter');
          }
          panel.classList.add('is-active');
        } else {
          panel.classList.remove('is-active', 'panel-enter');
          panel.classList.add('is-hidden');
        }
      });
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.tabId;
        if (!id) return;
        setActiveTab(id);
      });
    });

    // Keyboard navigation for tabs
    const tabList = root.querySelector('[role="tablist"]');
    if (tabList) {
      tabList.addEventListener('keydown', (event) => {
        const current = document.activeElement;
        if (!current || current.getAttribute('role') !== 'tab') return;

        let newIndex = Array.from(tabButtons).indexOf(current);
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          newIndex = (newIndex + 1) % tabButtons.length;
          tabButtons[newIndex].focus();
          tabButtons[newIndex].click();
        } else if (event.key === 'ArrowLeft') {
          event.preventDefault();
          newIndex = (newIndex - 1 + tabButtons.length) % tabButtons.length;
          tabButtons[newIndex].focus();
          tabButtons[newIndex].click();
        }
      });
    }

    // Accordion (grupy w kategoriach) – stale rozwinięte, bez interakcji

    // Subtabs for orthodontics
    const subtabRoots = root.querySelectorAll('[data-subtabs-root]');
    subtabRoots.forEach((rootEl) => {
      const subTabs = rootEl.querySelectorAll('.cennik-subtab');
      const panelContainer = rootEl
        .closest('.cennik-panel')
        ?.querySelectorAll('.cennik-subpanel');
      if (!subTabs.length || !panelContainer?.length) return;

      subTabs.forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.subtabId;
          if (!id) return;

          subTabs.forEach((b) => b.classList.toggle('is-active', b === btn));
          panelContainer.forEach((panel) => {
            const match = panel.dataset.subpanelId === id;
            panel.classList.toggle('is-active', match);
            panel.classList.toggle('is-hidden', !match);
          });
        });
      });
    });

    // Intersection observer animations
    if (!prefersReduced && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            header?.classList.add('animate-in');
            tabsWrapper?.classList.add('animate-in');
            cards.forEach((card) => {
              card.classList.add('animate-in');
            });
            highlight?.classList.add('animate-in');
            infoBoxes.forEach((box) => box.classList.add('animate-in'));
            accordions.forEach((acc) => acc.classList.add('animate-in'));
            ctaWrapper?.classList.add('animate-in');

            obs.disconnect();
          });
        },
        { threshold: 0.15 }
      );

      observer.observe(section);
    } else {
      // No animations
      header?.classList.remove('opacity-0', 'translate-y-3');
      tabsWrapper?.classList.remove('opacity-0', 'translate-y-3');
      cards.forEach((card) => card.classList.remove('opacity-0', 'translate-y-3'));
      highlight?.classList.remove('opacity-0', 'translate-y-3');
      infoBoxes.forEach((box) =>
        box.classList.remove('opacity-0', 'translate-y-3')
      );
      accordions.forEach((acc) =>
        acc.classList.remove('opacity-0', 'translate-y-3')
      );
      ctaWrapper?.classList.remove('opacity-0', 'translate-y-3');
    }
  });
</script>

<style>
  .cennik-section {
    scroll-margin-top: 6rem;
  }

  .cennik-tabs-scroll {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    padding-bottom: 0.25rem;
  }

  .cennik-tab {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.8);
    color: #4b5563;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.18s ease, background-color 0.18s ease, border-color 0.18s ease,
      transform 0.18s ease, box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .cennik-subtabs-scroll {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
  }

  .cennik-subtab {
    flex: 0 0 auto;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: #ffffff;
    color: #6b7280;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.18s ease, background-color 0.18s ease,
      border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .cennik-subtab.is-active {
    border-color: rgba(178, 148, 94, 0.7);
    background: #fefce8;
    color: #0a192f;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
    transform: translateY(-1px);
  }

  .cennik-subpanel.is-hidden {
    display: none;
  }


  .cennik-tab-icon {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .cennik-tab.is-active {
    border-color: rgba(178, 148, 94, 0.7);
    background: #ffffff;
    color: #0a192f;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .cennik-panel {
    transition: opacity 0.22s ease-out, transform 0.22s ease-out;
  }

  .cennik-panel.is-hidden {
    display: none;
  }

  .panel-enter {
    animation: panelIn 220ms ease-out forwards;
  }

  @keyframes panelIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .price-card {
    transition: transform 180ms ease, box-shadow 180ms ease,
      opacity 220ms ease-out, transform 220ms ease-out;
  }

  .price-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .price-card-highlight {
    border-left-width: 3px;
  }

  .cennik-infobox {
    background: #f9fafb;
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid #b2945e;
  }

  .cennik-accordion-body {
    overflow: visible;
    max-height: none;
  }

  .cennik-accordion-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .cennik-header,
  .cennik-tabs-wrapper,
  .price-card[data-card],
  .price-card-highlight,
  .cennik-infobox,
  .cennik-accordion,
  .cta-wrapper {
    opacity: 0;
    transform: translateY(8px);
  }

  .cennik-header.animate-in,
  .cennik-tabs-wrapper.animate-in,
  .price-card.animate-in,
  .price-card-highlight.animate-in,
  .cennik-infobox.animate-in,
  .cennik-accordion.animate-in,
  .cta-wrapper.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .cennik-tabs-scroll {
      justify-content: center;
      flex-wrap: wrap;
    }
  }

  @media (min-width: 1024px) {
    .cennik-tab {
      flex: 0 1 calc(25% - 0.75rem);
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }
</style>

