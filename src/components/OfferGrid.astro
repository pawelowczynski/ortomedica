---
---

<section id="oferta" class="py-24 md:py-32 bg-[#f8f7f4] relative">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
      <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Co oferujemy</span>
      <h2 class="cinzel text-3xl md:text-4xl text-navy mb-6">Zakres leczenia ortodontycznego</h2>
      <p class="text-gray-600 font-light">
        Rozwiązujemy problemy ze zgryzem, stosując sprawdzone metody dopasowane do Twojego wieku i stylu życia.
      </p>
    </div>

    <!-- FEATURED: Aparat stały metalowy -->
    <a
      href="/zabiegi/aparat-staly-metalowy"
      class="block bg-white rounded-3xl border border-gray-100 shadow-sm px-6 py-6 md:px-10 md:py-8 mb-10 md:mb-12 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300"
    >
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 md:gap-10">
        <div class="flex-1 min-w-0">
          <span
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gold/10 text-[11px] font-semibold uppercase tracking-[0.16em] text-gold mb-3"
          >
            <i data-lucide="settings" class="w-3.5 h-3.5"></i>
            Sprawdzone leczenie stałe
          </span>
          <h3 class="cinzel text-2xl md:text-3xl text-navy mb-3">Aparat stały metalowy</h3>
          <p class="text-sm md:text-[15px] text-gray-600 font-light leading-relaxed max-w-xl">
            Klasyczne zamki metalowe, skuteczne w leczeniu większości wad zgryzu u dorosłych i młodzieży. Stabilna metoda, którą można dopasować do Twoich potrzeb i planu leczenia.
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-gold mt-4">
            Poznaj szczegóły
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </span>
        </div>
        <div class="md:text-right md:pl-4 flex-shrink-0 text-left text-sm text-gray-500">
          <p class="uppercase tracking-[0.16em] text-[11px] text-gray-400 mb-1">Dla kogo</p>
          <p>Leczenie stałe dla młodzieży i dorosłych przy typowych i złożonych wadach zgryzu.</p>
        </div>
      </div>
    </a>

    <!-- POZOSTAŁE ZABIEGI -->
    <nav aria-label="Zabiegi ortodontyczne">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
        <!-- Nakładki Invisalign -->
        <a
          href="/zabiegi/invisalign-lubin"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center mr-3">
            <i data-lucide="sparkles" class="w-5 h-5"></i>
          </div>
          <div class="flex items-center justify-between gap-3 mb-1">
            <h4 class="text-sm font-semibold text-navy flex-1">Nakładki Invisalign</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Niewidoczne nakładki dla dorosłych i młodzieży.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Aparat stały ceramiczny -->
        <a
          href="/zabiegi/aparat-staly-ceramiczny"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center">
              <i data-lucide="sparkles" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Aparat stały ceramiczny</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Estetyczne zamki porcelanowe lub szafirowe.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Ortodoncja dziecięca -->
        <a
          href="/zabiegi/ortodoncja-dziecieca"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
              <i data-lucide="baby" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Ortodoncja dziecięca</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Leczenie przechwytujące od 7. roku życia.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Skan 3D iTero -->
        <a
          href="/zabiegi/skan-3d-itero"
          class="group bg-emerald-50/60 rounded-2xl border border-emerald-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center">
              <i data-lucide="scan-line" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Skan 3D iTero</h4>
          </div>
          <p class="text-[13px] text-gray-600 font-light mb-3 flex-1">
            Cyfrowy wycisk i symulacja uśmiechu na miejscu.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 group-hover:bg-emerald-200 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Leczenie wad zgryzu -->
        <a
          href="/zabiegi/leczenie-wad-zgryzu"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-navy/5 text-navy flex items-center justify-center">
              <i data-lucide="activity" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Leczenie wad zgryzu</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Zgryz otwarty, głęboki, krzyżowy, stłoczenia.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Retencja -->
        <a
          href="/zabiegi/retencja-ortodontyczna"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-700 flex items-center justify-center">
              <i data-lucide="shield-check" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Retencja po leczeniu</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Aparaty retencyjne stałe i zdejmowane.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Aparat ruchomy -->
        <a
          href="/zabiegi/aparat-ruchomy"
          class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
              <i data-lucide="toy-brick" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Aparat ruchomy</h4>
          </div>
          <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
            Zdejmowany aparat dla dzieci w fazie wzrostu.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>

        <!-- Konsultacja -->
        <a
          href="/zabiegi/konsultacja-ortodontyczna"
          class="group bg-emerald-50/60 rounded-2xl border border-emerald-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center">
              <i data-lucide="calendar-clock" class="w-5 h-5"></i>
            </div>
            <h4 class="text-sm font-semibold text-navy flex-1">Konsultacja ortodontyczna</h4>
          </div>
          <p class="text-[13px] text-gray-600 font-light mb-3 flex-1">
            Pierwsze badanie, wywiad i plan leczenia.
          </p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
            <span
              class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 group-hover:bg-emerald-200 transition-colors"
            >
              <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </span>
          </div>
        </a>
      </div>
    </nav>

    <div class="mt-16 text-center">
      <a href="#kontakt" class="btn-gold px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider inline-flex items-center gap-2">
        Umów konsultację
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</section>

