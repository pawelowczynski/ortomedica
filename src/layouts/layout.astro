---
import '../styles/global.css';
const { title, description, canonical = 'https://orthomedica-lubin.pl/', image = 'https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=1200' } = Astro.props;
---
<!DOCTYPE html>
<html lang="pl" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonical}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={image}>
    <meta property="og:locale" content="pl_PL">
    <meta property="og:site_name" content="ORTHOMEDICA">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={image}>

    <slot name="head" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <style is:global>
        /* Te style będą działać na każdej podstronie */
        :root {
            --navy: #0a192f;
            --navy-light: #112240;
            --gold: #b2945e;
            --white: #fcfcfc;
        }
        body { font-family: 'Montserrat', sans-serif; background-color: var(--white); color: var(--navy); overflow-x: hidden; }
        .cinzel { font-family: 'Cinzel', serif; }
        .serif { font-family: 'Playfair Display', serif; }

        /* Style Nawigacji */
        #main-nav.scrolled { background: rgba(255, 255, 255, 0.98); padding-top: 0.5rem; padding-bottom: 0.5rem; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1); color: var(--navy) !important; }
        #main-nav.scrolled .nav-link, #main-nav.scrolled .brand-text { color: var(--navy); }
        
        /* Style Przycisków */
        .btn-gold { background-color: var(--gold) !important; color: white !important; border: 1px solid var(--gold); transition: all 0.3s ease; }
        .btn-gold:hover { background-color: transparent !important; color: var(--gold) !important; }

        /* Tła sekcji */
        .hero-bg { 
            background-image: linear-gradient(rgba(10, 25, 47, 0.75), rgba(10, 25, 47, 0.65)), url('https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=2070'); 
            background-position: center; 
            background-size: cover;
        }
        @media (min-width: 1024px) { .hero-bg { background-attachment: fixed; } }

        /* Pola formularza */
        .input-field { display: block; width: 100%; padding: 0.75rem 1rem; border: 1px solid #e5e7eb; border-radius: 0.75rem; background: #fff; color: var(--navy); outline: none; transition: border-color 0.2s; }
        .input-field:focus { border-color: var(--gold); }
        .input-field::placeholder { color: #9ca3af; }

        /* RODO i inne */
        #cookie-banner.hidden-banner { opacity: 0; pointer-events: none; transform: translateY(20px); }
        .ba-container { touch-action: pan-y; }
        .ba-label { letter-spacing: 0.2em; }
        .ba-label-przed { background-color: var(--navy) !important; }
        .ba-label-po { background-color: var(--gold) !important; color: #fff !important; }
    </style>
</head>
<body class="antialiased pb-20 md:pb-0 relative">
    <slot />
    <script type="module" src="/main.js"></script>
</body>
</html>