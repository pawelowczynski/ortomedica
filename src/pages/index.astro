---
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import Cennik from '../components/Cennik.astro';
import Hero from '../components/Hero.astro';
import OfferGrid from '../components/OfferGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Metamorphoses from '../components/Metamorphoses.astro';
import Team from '../components/Team.astro';
import Testimonials from '../components/Testimonials.astro';
import ClinicGallery from '../components/ClinicGallery.astro';
import LocalSEO from '../components/LocalSEO.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactSection from '../components/ContactSection.astro';
import { DEFAULT_OG_IMAGE_URL } from '../data/site';
import { homePageFaqs } from '../data/faq';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homePageFaqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout 
    title="ORTHOMEDICA Lubin | Stomatologia dziecięca, chirurgia, gnatologia, ortodoncja"
    description="ORTHOMEDICA w Lubinie: stomatologia dziecięca, ortodoncja, chirurgia i gnatologia u dr n. med. Kornelii Rumin. Od dokładnej diagnostyki po spójny plan leczenia — z myślą o komforcie dziecka i spokoju rodzica. Umów wizytę w dogodnym terminie."
>
    <!-- Tu zrzucamy specyficzne tagi SEO dla tej strony (Schema.org) -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "MedicalBusiness",
          "name": "ORTHOMEDICA - dr n. med. Kornelia Rumin",
          "description": "Stomatologia dziecięca, chirurgia, gnatologia i ortodoncja — Lubin.",
          "image": DEFAULT_OG_IMAGE_URL,
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "ul. Pawia 67",
            "addressLocality": "Lubin",
            "postalCode": "59-300",
            "addressCountry": "PL"
          },
          "telephone": "+48694731124",
          "email": "rejestracja@orthomedica-lubin.pl",
          "url": "https://www.orthomedica.lubin.pl",
          "priceRange": "PLN",
          "openingHoursSpecification": [
            { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "18:00" }
          ]
        },
        {
          "@type": "Physician",
          "name": "dr n. med. Kornelia Rumin",
          "jobTitle": "Lekarz ortodonta",
          "worksFor": { "@type": "MedicalBusiness", "name": "ORTHOMEDICA" }
        }
      ]
    })} />

    <Header />
    
    <main id="main-content">
        <Hero />
        <OfferGrid />
        <ProcessSteps />
        <Metamorphoses />
        <Team />
        <Testimonials />
        <ClinicGallery />

        <Cennik />

        <FAQSection />

        <ContactSection />
        <LocalSEO />
    </main>

    <Footer />
</Layout>