---
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import Cennik from '../components/Cennik.astro';
---

<Layout 
    title="Ortodonta Lubin - dr n. med. Kornelia Rumin | ORTHOMEDICA"
    description="Ortodonta w Lubinie – dr n. med. Kornelia Rumin. Usługi ortodontyczne: Invisalign, aparaty stałe, ortodoncja dziecięca."
>
    <!-- Tu zrzucamy specyficzne tagi SEO dla tej strony (Schema.org) -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "MedicalBusiness",
          "name": "ORTHOMEDICA - dr n. med. Kornelia Rumin",
          "image": "https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=1200",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "ul. Pawia 67",
            "addressLocality": "Lubin",
            "postalCode": "59-300",
            "addressCountry": "PL"
          },
          "telephone": "+48789012345",
          "email": "rejestracja@orthomedica-lubin.pl",
          "url": "https://orthomedica-lubin.pl",
          "priceRange": "PLN",
          "openingHoursSpecification": [
            { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "18:00" }
          ],
          "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142", "bestRating": "5" }
        },
        {
          "@type": "Physician",
          "name": "dr n. med. Kornelia Rumin",
          "jobTitle": "Lekarz ortodonta",
          "worksFor": { "@type": "MedicalBusiness", "name": "ORTHOMEDICA" }
        }
      ]
    })} />

    <Header />
    
    <main id="main-content">
        <!-- H1 HERO -->
        <section id="home" class="min-h-screen hero-bg flex items-center relative overflow-hidden pt-24">
            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-4xl">
                    <span class="text-gold font-bold tracking-[0.5em] text-[10px] md:text-xs uppercase mb-6 block drop-shadow-md">Ekspert ortodoncji | Lubin i okolice</span>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl serif mb-6 leading-tight text-white drop-shadow-xl">
                        Dr n. med. Kornelia Rumin
                        <br />
                        <span class="text-gold italic drop-shadow-md">Ortodonta w Lubinie</span>
                    </h1>
                    <p class="text-lg md:text-2xl font-light mb-10 text-white/95 max-w-2xl leading-relaxed drop-shadow-md">
                        Piękny uśmiech to inwestycja na całe życie. Nowoczesne metody leczenia wad zgryzu, w tym niewidoczne nakładki Invisalign, dopasowane do Twoich potrzeb.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
                        <a href="#kontakt" class="btn-gold px-10 py-5 rounded-full font-bold text-sm uppercase tracking-[0.2em] shadow-xl flex items-center justify-center gap-3 group">
                            Umów wizytę
                            <i data-lucide="calendar" class="w-4 h-4 transition-transform group-hover:scale-110"></i>
                        </a>
                        <a href="#oferta" class="bg-white/10 backdrop-blur-sm text-white border border-white/30 px-10 py-5 rounded-full font-bold text-sm uppercase tracking-[0.2em] hover:bg-white hover:text-navy transition-all flex items-center justify-center text-center">
                            Poznaj metody
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Trust Signals Overlapping Hero -->
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-[#0a192f] to-transparent pt-32 pb-6 hidden md:block">
                <div class="container mx-auto px-6">
                    <div class="grid grid-cols-3 gap-8 border-t border-white/20 pt-6">
                        <div class="text-white">
                            <p class="text-3xl font-bold text-gold mb-1">12+</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Lat doświadczenia</p>
                        </div>
                        <div class="text-white border-l border-white/20 pl-8">
                            <p class="text-3xl font-bold text-gold mb-1">2500+</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Pięknych uśmiechów</p>
                        </div>
                        <div class="text-white border-l border-white/20 pl-8">
                            <p class="text-3xl font-bold text-gold mb-1">Certyfikat</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Invisalign Expert</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Trust Signals Mobile -->
        <section class="bg-navy py-10 md:hidden">
            <div class="container mx-auto px-6 flex justify-around text-center">
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">15+</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Lat praktyki</p>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">2500+</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Pacjentów</p>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">4.9</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Opinie Google</p>
                </div>
            </div>
        </section>

        <!-- Oferta -->
        <section id="oferta" class="py-24 md:py-32 bg-[#f8f7f4] relative">
            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
                    <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Co oferujemy</span>
                    <h2 class="cinzel text-3xl md:text-4xl text-navy mb-6">Zakres leczenia ortodontycznego</h2>
                    <p class="text-gray-600 font-light">
                        Rozwiązujemy problemy ze zgryzem, stosując sprawdzone metody dopasowane do Twojego wieku i stylu życia.
                    </p>
                </div>

                <!-- FEATURED: Aparat stały metalowy -->
                <a href="/zabiegi/aparat-staly-metalowy" class="block bg-white rounded-3xl border border-gray-100 shadow-sm px-6 py-6 md:px-10 md:py-8 mb-10 md:mb-12 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
                    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 md:gap-10">
                        <div class="flex-1 min-w-0">
                            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gold/10 text-[11px] font-semibold uppercase tracking-[0.16em] text-gold mb-3">
                                <i data-lucide="settings" class="w-3.5 h-3.5"></i>
                                Sprawdzone leczenie stałe
                            </span>
                            <h3 class="cinzel text-2xl md:text-3xl text-navy mb-3">Aparat stały metalowy</h3>
                            <p class="text-sm md:text-[15px] text-gray-600 font-light leading-relaxed max-w-xl">
                                Klasyczne zamki metalowe, skuteczne w leczeniu większości wad zgryzu u dorosłych i młodzieży. Stabilna metoda, którą można dopasować do Twoich potrzeb i planu leczenia.
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-semibold text-gold mt-4">
                                Poznaj szczegóły
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </span>
                        </div>
                        <div class="md:text-right md:pl-4 flex-shrink-0 text-left text-sm text-gray-500">
                            <p class="uppercase tracking-[0.16em] text-[11px] text-gray-400 mb-1">Dla kogo</p>
                            <p>Leczenie stałe dla młodzieży i dorosłych przy typowych i złożonych wadach zgryzu.</p>
                        </div>
                    </div>
                </a>

                <!-- POZOSTAŁE ZABIEGI -->
                <nav aria-label="Zabiegi ortodontyczne">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
                        <!-- Aparat stały metalowy -->
                        <a href="/zabiegi/invisalign-lubin" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center mr-3">
                                <i data-lucide="sparkles" class="w-5 h-5"></i>
                            </div>
                            <div class="flex items-center justify-between gap-3 mb-1">
                                <h4 class="text-sm font-semibold text-navy flex-1">Nakładki Invisalign</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Niewidoczne nakładki dla dorosłych i młodzieży.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Aparat stały metalowy -->
                        <a href="/zabiegi/aparat-staly-metalowy" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center">
                                    <i data-lucide="settings" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Aparat stały metalowy</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Klasyczne zamki, skuteczne przy każdej wadzie zgryzu.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Aparat stały ceramiczny -->
                        <a href="/zabiegi/aparat-staly-ceramiczny" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center">
                                    <i data-lucide="sparkles" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Aparat stały ceramiczny</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Estetyczne zamki porcelanowe lub szafirowe.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Ortodoncja dziecięca -->
                        <a href="/zabiegi/ortodoncja-dziecieca" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
                                    <i data-lucide="baby" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Ortodoncja dziecięca</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Leczenie przechwytujące od 7. roku życia.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Skan 3D iTero -->
                        <a href="/zabiegi/skan-3d-itero" class="group bg-emerald-50/60 rounded-2xl border border-emerald-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center">
                                    <i data-lucide="scan-line" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Skan 3D iTero</h4>
                            </div>
                            <p class="text-[13px] text-gray-600 font-light mb-3 flex-1">
                                Cyfrowy wycisk i symulacja uśmiechu na miejscu.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 group-hover:bg-emerald-200 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Leczenie wad zgryzu -->
                        <a href="/zabiegi/leczenie-wad-zgryzu" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-navy/5 text-navy flex items-center justify-center">
                                    <i data-lucide="activity" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Leczenie wad zgryzu</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Zgryz otwarty, głęboki, krzyżowy, stłoczenia.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Retencja -->
                        <a href="/zabiegi/retencja-ortodontyczna" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-700 flex items-center justify-center">
                                    <i data-lucide="shield-check" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Retencja po leczeniu</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Aparaty retencyjne stałe i zdejmowane.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Aparat ruchomy -->
                        <a href="/zabiegi/aparat-ruchomy" class="group bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
                                    <i data-lucide="toy-brick" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Aparat ruchomy</h4>
                            </div>
                            <p class="text-[13px] text-gray-500 font-light mb-3 flex-1">
                                Zdejmowany aparat dla dzieci w fazie wzrostu.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-navy group-hover:bg-gold/10 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>

                        <!-- Konsultacja -->
                        <a href="/zabiegi/konsultacja-ortodontyczna" class="group bg-emerald-50/60 rounded-2xl border border-emerald-100 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center">
                                    <i data-lucide="calendar-clock" class="w-5 h-5"></i>
                                </div>
                                <h4 class="text-sm font-semibold text-navy flex-1">Konsultacja ortodontyczna</h4>
                            </div>
                            <p class="text-[13px] text-gray-600 font-light mb-3 flex-1">
                                Pierwsze badanie, wywiad i plan leczenia.
                            </p>
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-[12px] font-semibold text-gold">Poznaj szczegóły</span>
                                <span class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 group-hover:bg-emerald-200 transition-colors">
                                    <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                </span>
                            </div>
                        </a>
                    </div>
                </nav>

                <div class="mt-16 text-center">
                    <a href="#kontakt" class="btn-gold px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider inline-flex items-center gap-2">
                        Umów konsultację
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- Proces / Pierwsza Wizyta -->
        <section id="pierwsza-wizyta" class="py-24 bg-navy text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Krok po kroku</span>
                    <h2 class="cinzel text-3xl md:text-4xl mb-4">Jak wygląda leczenie?</h2>
                    <p class="text-white/70 font-light">Przejrzysty proces. Od diagnozy po wymarzony uśmiech.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">1</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Konsultacja</h4>
                        <p class="text-sm text-white/60 font-light">Wywiad, badanie zgryzu i omówienie Twoich oczekiwań.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">2</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Diagnostyka 3D</h4>
                        <p class="text-sm text-white/60 font-light">Cyfrowy skan iTero, zdjęcia RTG oraz fotografie twarzy.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">3</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Plan Leczenia</h4>
                        <p class="text-sm text-white/60 font-light">Omówienie symulacji wyników, kosztorysu i harmonogramu.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">4</span></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Start</h4>
                        <p class="text-sm text-white/60 font-light">Założenie aparatu lub wydanie pierwszych nakładek.</p>
                    </div>
                </div>
                
                <div class="mt-16 text-center">
                    <a href="#kontakt" class="inline-block bg-gold hover:bg-white hover:text-navy text-white border border-gold px-8 py-4 rounded-full font-bold text-xs uppercase tracking-[0.2em] transition-all">Zrób pierwszy krok</a>
                </div>
            </div>
        </section>

        <!-- Metamorfozy -->
        <section id="metamorfozy" class="py-24 md:py-32 bg-[#f8f7f4]">
            <div class="container mx-auto px-6">
                <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
