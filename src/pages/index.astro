---
import layout from '../layouts/layout.astro';
import header from '../components/header.astro';
import footer from '../components/hooter.astro';
---

<layout 
    title="Ortodonta Lubin - dr n. med. Kornelia Rumin | ORTHOMEDICA"
    description="Ortodonta w Lubinie – dr n. med. Kornelia Rumin. Usługi ortodontyczne: Invisalign, aparaty stałe, ortodoncja dziecięca."
>
    <!-- Tu zrzucamy specyficzne tagi SEO dla tej strony (Schema.org) -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "MedicalBusiness",
          "name": "ORTHOMEDICA - dr n. med. Kornelia Rumin",
          "image": "https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=1200",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "ul. Pawia 67",
            "addressLocality": "Lubin",
            "postalCode": "59-300",
            "addressCountry": "PL"
          },
          "telephone": "+48789012345",
          "email": "rejestracja@orthomedica-lubin.pl",
          "url": "https://orthomedica-lubin.pl",
          "priceRange": "PLN",
          "openingHoursSpecification": [
            { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "18:00" }
          ],
          "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "142", "bestRating": "5" }
        },
        {
          "@type": "Physician",
          "name": "dr n. med. Kornelia Rumin",
          "jobTitle": "Lekarz ortodonta",
          "worksFor": { "@type": "MedicalBusiness", "name": "ORTHOMEDICA" }
        }
      ]
    })} />

    <Header />
    
    <main id="main-content">
        <!-- H1 HERO -->
        <section id="home" class="min-h-screen hero-bg flex items-center relative overflow-hidden pt-24">
            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-4xl">
                    <span class="text-gold font-bold tracking-[0.5em] text-[10px] md:text-xs uppercase mb-6 block drop-shadow-md">Ekspert ortodoncji | Lubin i okolice</span>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl serif mb-6 leading-tight text-white drop-shadow-xl">Ortodonta Lubin<br><span class="text-gold italic drop-shadow-md">dr Kornelia Rumin</span></h1>
                    <p class="text-lg md:text-2xl font-light mb-10 text-white/95 max-w-2xl leading-relaxed drop-shadow-md">
                        Piękny uśmiech to inwestycja na całe życie. Nowoczesne metody leczenia wad zgryzu, w tym niewidoczne nakładki Invisalign, dopasowane do Twoich potrzeb.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
                        <a href="#kontakt" class="btn-gold px-10 py-5 rounded-full font-bold text-sm uppercase tracking-[0.2em] shadow-xl flex items-center justify-center gap-3 group">
                            Umów wizytę
                            <i data-lucide="calendar" class="w-4 h-4 transition-transform group-hover:scale-110"></i>
                        </a>
                        <a href="#oferta" class="bg-white/10 backdrop-blur-sm text-white border border-white/30 px-10 py-5 rounded-full font-bold text-sm uppercase tracking-[0.2em] hover:bg-white hover:text-navy transition-all flex items-center justify-center text-center">
                            Poznaj metody
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Trust Signals Overlapping Hero -->
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-[#0a192f] to-transparent pt-32 pb-6 hidden md:block">
                <div class="container mx-auto px-6">
                    <div class="grid grid-cols-3 gap-8 border-t border-white/20 pt-6">
                        <div class="text-white">
                            <p class="text-3xl font-bold text-gold mb-1">12+</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Lat doświadczenia</p>
                        </div>
                        <div class="text-white border-l border-white/20 pl-8">
                            <p class="text-3xl font-bold text-gold mb-1">2500+</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Pięknych uśmiechów</p>
                        </div>
                        <div class="text-white border-l border-white/20 pl-8">
                            <p class="text-3xl font-bold text-gold mb-1">Certyfikat</p>
                            <p class="text-xs uppercase tracking-widest opacity-80">Invisalign Expert</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Trust Signals Mobile -->
        <section class="bg-navy py-10 md:hidden">
            <div class="container mx-auto px-6 flex justify-around text-center">
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">12+</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Lat praktyki</p>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">2500+</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Pacjentów</p>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gold mb-1">4.9</p>
                    <p class="text-[10px] uppercase tracking-widest text-white/80">Opinie Google</p>
                </div>
            </div>
        </section>

        <!-- O mnie -->
        <section id="o-mnie" class="py-24 md:py-32 bg-white">
            <div class="container mx-auto px-6">
                <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
                    <div class="relative order-2 lg:order-1">
                        <div class="absolute -top-6 -left-6 md:-top-10 md:-left-10 w-48 h-48 md:w-64 md:h-64 bg-gold/10 rounded-full -z-0"></div>
                        <div class="absolute -bottom-6 -right-6 w-32 h-32 border-2 border-gold/30 rounded-full -z-0"></div>
                        <img id="doctor-img" src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&q=80&w=800" alt="dr n. med. Kornelia Rumin" loading="lazy" class="doctor-photo rounded-3xl shadow-2xl relative z-10 w-full object-cover aspect-[4/5] md:aspect-[3/4]">
                    </div>
                    <div class="order-1 lg:order-2">
                        <h2 class="cinzel text-[10px] md:text-xs text-gold font-bold tracking-[0.5em] mb-4 uppercase italic">Pasja i Doświadczenie</h2>
                        <h3 class="text-3xl md:text-4xl lg:text-5xl serif mb-6 md:mb-8 text-navy">dr n. med. Kornelia Rumin</h3>
                        <article class="prose prose-lg text-gray-600 font-light mb-8">
                            <p class="mb-4">Jako lekarz ortodonta z wieloletnim stażem, łączę wiedzę medyczną z nowoczesnymi technologiami. Moim celem nie jest tylko "prostowanie zębów", ale harmonijna przebudowa uśmiechu i profilu twarzy pacjenta.</p>
                            <p>W naszej nowoczesnej klinice w sercu Zagłębia Miedziowego przyjmuję pacjentów z Lubina, Polkowic, Legnicy i okolic. Wykorzystuję skanery wewnątrzustne 3D, co eliminuje konieczność pobierania nieprzyjemnych wycisków.</p>
                        </article>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
                            <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100">
                                <i data-lucide="award" class="text-gold mt-1 shrink-0"></i>
                                <div>
                                    <h4 class="font-bold text-navy mb-1 uppercase text-[11px] tracking-wider">Ekspert Invisalign</h4>
                                    <p class="text-xs text-gray-500">Certyfikowany lekarz systemu przeźroczystych nakładek.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100">
                                <i data-lucide="scan-line" class="text-gold mt-1 shrink-0"></i>
                                <div>
                                    <h4 class="font-bold text-navy mb-1 uppercase text-[11px] tracking-wider">Skaner 3D iTero</h4>
                                    <p class="text-xs text-gray-500">Cyfrowe wyciski, pełen komfort, natychmiastowa symulacja uśmiechu.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Klinika / Wnętrza -->
        <section id="klinika" class="py-24 bg-navy text-white relative border-t border-white/10">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Nasza przestrzeń</span>
                    <h2 class="cinzel text-3xl md:text-4xl mb-4">Nowoczesna Klinika</h2>
                    <p class="text-white/70 font-light text-sm max-w-2xl mx-auto">Zaprojektowana z myślą o Twoim komforcie i poczuciu bezpieczeństwa. Wyposażona w sprzęt diagnostyczny światowej klasy, eliminujący stres i ból.</p>
                </div>
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    <div class="overflow-hidden rounded-2xl group col-span-2 row-span-2 relative bg-navy-light">
                        <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800" alt="Przestronna recepcja kliniki" loading="lazy" class="w-full h-full min-h-[300px] object-cover transition-transform duration-700 group-hover:scale-105">
                        <div class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-4 py-2 rounded-lg text-[10px] uppercase tracking-widest font-bold border border-white/10">Strefa relaksu</div>
                    </div>
                    <div class="overflow-hidden rounded-2xl group relative bg-navy-light">
                        <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=400" alt="Skaner 3D" loading="lazy" class="w-full h-48 md:h-full object-cover transition-transform duration-700 group-hover:scale-105">
                        <div class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-3 py-1.5 rounded-lg text-[9px] uppercase tracking-widest font-bold border border-white/10">Diagnostyka 3D</div>
                    </div>
                    <div class="overflow-hidden rounded-2xl group relative bg-navy-light">
                        <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=400" alt="Nowoczesny fotel" loading="lazy" class="w-full h-48 md:h-full object-cover transition-transform duration-700 group-hover:scale-105">
                        <div class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-3 py-1.5 rounded-lg text-[9px] uppercase tracking-widest font-bold border border-white/10">Gabinety</div>
                    </div>
                    <div class="overflow-hidden rounded-2xl group col-span-2 relative bg-navy-light">
                        <img src="https://images.unsplash.com/photo-1598045618451-f762dd762f01?auto=format&fit=crop&q=80&w=800" alt="Zespół kliniki" loading="lazy" class="w-full h-48 md:h-64 object-cover transition-transform duration-700 group-hover:scale-105 object-top">
                        <div class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur px-4 py-2 rounded-lg text-[10px] uppercase tracking-widest font-bold border border-white/10">Opieka asystentek</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Oferta -->
        <section id="oferta" class="py-24 md:py-32 bg-gray-50 relative">
            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
                    <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Co oferujemy</span>
                    <h2 class="cinzel text-3xl md:text-4xl text-navy mb-6">Zakres leczenia ortodontycznego</h2>
                    <p class="text-gray-600 font-light">Rozwiązujemy problemy ze zgryzem, stosując sprawdzone metody dopasowane do Twojego wieku i stylu życia.</p>
                </div>
                
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
                    <!-- Card 1 -->
                    <article class="bg-white p-8 md:p-12 rounded-[2rem] shadow-sm border border-gray-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 service-card">
                        <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center text-gold mb-8 service-icon transition-transform"><i data-lucide="sparkles" class="w-8 h-8"></i></div>
                        <h3 class="cinzel text-xl md:text-2xl mb-4 text-navy">Nakładki Invisalign</h3>
                        <p class="text-gray-500 text-sm font-light leading-relaxed mb-8">Niewidoczne, wygodne nakładki prostujące zęby. Popularna wśród dorosłych i młodzieży ze względu na dyskrecję i brak ograniczeń w jedzeniu.</p>
                    </article>

                    <!-- Card 2 -->
                    <article class="bg-white p-8 md:p-12 rounded-[2rem] shadow-sm border border-gray-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 service-card">
                        <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center text-gold mb-8 service-icon transition-transform"><i data-lucide="baby" class="w-8 h-8"></i></div>
                        <h3 class="cinzel text-xl md:text-2xl mb-4 text-navy">Ortodoncja Dziecięca</h3>
                        <p class="text-gray-500 text-sm font-light leading-relaxed mb-8">Leczenie przechwytujące dla dzieci. Stosujemy aparaty ruchome i aparaty do rozbudowy podniebienia, aby zapewnić miejsce dla zębów stałych.</p>
                    </article>

                    <!-- Card 3 -->
                    <article class="bg-white p-8 md:p-12 rounded-[2rem] shadow-sm border border-gray-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 service-card">
                        <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center text-gold mb-8 service-icon transition-transform"><i data-lucide="smile" class="w-8 h-8"></i></div>
                        <h3 class="cinzel text-xl md:text-2xl mb-4 text-navy">Aparaty Stałe</h3>
                        <p class="text-gray-500 text-sm font-light leading-relaxed mb-8">Klasyczne zamki metalowe oraz estetyczne zamki porcelanowe i szafirowe. Sprawdzone, skuteczne metody radzenia sobie z różnymi wadami zgryzu.</p>
                    </article>
                </div>
                <div class="mt-16 text-center">
                    <a href="#kontakt" class="btn-gold px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider inline-flex items-center gap-2">
                        Umów konsultację
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- Proces / Pierwsza Wizyta -->
        <section id="pierwsza-wizyta" class="py-24 bg-navy text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Krok po kroku</span>
                    <h2 class="cinzel text-3xl md:text-4xl mb-4">Jak wygląda leczenie?</h2>
                    <p class="text-white/70 font-light">Przejrzysty proces. Od diagnozy po wymarzony uśmiech.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">1</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Konsultacja</h4>
                        <p class="text-sm text-white/60 font-light">Wywiad, badanie zgryzu i omówienie Twoich oczekiwań.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">2</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Diagnostyka 3D</h4>
                        <p class="text-sm text-white/60 font-light">Cyfrowy skan iTero, zdjęcia RTG oraz fotografie twarzy.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">3</span></div>
                        <div class="hidden md:block absolute top-10 left-[60%] w-[80%] border-t border-dashed border-white/20"></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Plan Leczenia</h4>
                        <p class="text-sm text-white/60 font-light">Omówienie symulacji wyników, kosztorysu i harmonogramu.</p>
                    </div>
                    <div class="text-center relative">
                        <div class="w-20 h-20 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-6 relative z-10"><span class="cinzel text-3xl text-gold font-bold">4</span></div>
                        <h4 class="font-bold uppercase tracking-widest text-xs mb-3">Start</h4>
                        <p class="text-sm text-white/60 font-light">Założenie aparatu lub wydanie pierwszych nakładek.</p>
                    </div>
                </div>
                
                <div class="mt-16 text-center">
                    <a href="#kontakt" class="inline-block bg-gold hover:bg-white hover:text-navy text-white border border-gold px-8 py-4 rounded-full font-bold text-xs uppercase tracking-[0.2em] transition-all">Zrób pierwszy krok</a>
                </div>
            </div>
        </section>

        <!-- Metamorfozy -->
        <section id="metamorfozy" class="py-24 md:py-32 bg-white">
            <div class="container mx-auto px-6">
                <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                    <div class="max-w-xl">
                        <span class="text-gold font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Galeria uśmiechów</span>
                        <h2 class="cinzel text-3xl md:text-4xl text-navy">Metamorfozy pacjentów</h2>
                    </div>
                    <p class="text-gray-500 font-light italic text-sm md:text-right max-w-sm">Przesuń suwak, aby zobaczyć autentyczne efekty leczenia w naszej klinice.</p>
                </div>

                <div class="grid md:grid-cols-2 gap-10">
                    <!-- Przykład 1 -->
                    <div class="group overflow-hidden rounded-[2rem] bg-gray-50 border border-gray-100 shadow-sm transition-all flex flex-col hover:shadow-xl">
                        <div class="relative w-full h-64 md:h-80 ba-container cursor-ew-resize select-none overflow-hidden rounded-t-[2rem]">
                            <div class="absolute inset-0 z-10 pointer-events-none">
                                <span class="absolute top-4 right-4 bg-gold text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-md">Po</span>
                                <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=600" alt="Po leczeniu" loading="lazy" class="w-full h-full object-cover block">
                            </div>
                            <div class="ba-before absolute inset-0 z-20 pointer-events-none" style="clip-path: inset(0 50% 0 0);">
                                <span class="absolute top-4 left-4 bg-navy/80 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider backdrop-blur-sm">Przed</span>
                                <img src="https://images.unsplash.com/photo-1598045618451-f762dd762f01?auto=format&fit=crop&q=80&w=600" alt="Przed leczeniem" loading="lazy" class="w-full h-full object-cover block filter grayscale opacity-90">
                                <div class="absolute top-0 right-0 w-0.5 h-full bg-gold"></div>
                            </div>
                            <div class="ba-slider-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 w-10 h-10 bg-white border-2 border-gold rounded-full flex items-center justify-center shadow-xl pointer-events-none transition-transform duration-200">
                                <i data-lucide="arrows-right-left" class="w-4 h-4 text-gold"></i>
                            </div>
                        </div>
                        <div class="p-8 grow bg-white">
                            <h4 class="cinzel text-lg md:text-xl mb-3 text-navy">Korekta głębokiego zgryzu i stłoczeń</h4>
                            <div class="flex gap-4 mb-2">
                                <span class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-gold bg-gold/10 px-2 py-1 rounded"><i data-lucide="tag" class="w-3 h-3"></i> Invisalign</span>
                            </div>
                            <p class="text-sm text-gray-500 font-light">Czas leczenia: 14 miesięcy.</p>
                        </div>
                    </div>

                    <!-- Przykład 2 -->
                    <div class="group overflow-hidden rounded-[2rem] bg-gray-50 border border-gray-100 shadow-sm transition-all flex flex-col hover:shadow-xl">
                        <div class="relative w-full h-64 md:h-80 ba-container cursor-ew-resize select-none overflow-hidden rounded-t-[2rem]">
                            <div class="absolute inset-0 z-10 pointer-events-none">
                                <span class="absolute top-4 right-4 bg-gold text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-md">Po</span>
                                <img src="https://images.unsplash.com/photo-1522845015757-50bce044e5da?auto=format&fit=crop&q=80&w=600" alt="Po leczeniu" loading="lazy" class="w-full h-full object-cover block">
                            </div>
                            <div class="ba-before absolute inset-0 z-20 pointer-events-none" style="clip-path: inset(0 50% 0 0);">
                                <span class="absolute top-4 left-4 bg-navy/80 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider backdrop-blur-sm">Przed</span>
                                <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=600" alt="Przed leczeniem" loading="lazy" class="w-full h-full object-cover block filter grayscale opacity-90">
                                <div class="absolute top-0 right-0 w-0.5 h-full bg-gold"></div>
                            </div>
                            <div class="ba-slider-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 w-10 h-10 bg-white border-2 border-gold rounded-full flex items-center justify-center shadow-xl pointer-events-none transition-transform duration-200">
                                <i data-lucide="arrows-right-left" class="w-4 h-4 text-gold"></i>
                            </div>
                        </div>
                        <div class="p-8 grow bg-white">
                            <h4 class="cinzel text-lg md:text-xl mb-3 text-navy">Zamknięcie diastemy i wyrównanie</h4>
                            <div class="flex gap-4 mb-2">
