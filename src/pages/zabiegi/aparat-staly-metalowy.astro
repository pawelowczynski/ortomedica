---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/footer.astro';
---

<Layout
  title="Aparat stały metalowy Lubin — klasyczne leczenie ortodontyczne | ORTHOMEDICA"
  description="Aparat stały metalowy w Lubinie — skuteczne leczenie większości wad zgryzu u dzieci, młodzieży i dorosłych. ORTHOMEDICA, dr n. med. Kornelia Rumin."
  canonical="https://orthomedica-lubin.pl/zabiegi/aparat-staly-metalowy"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalProcedure",
    "name": "Aparat stały metalowy",
    "url": "https://orthomedica-lubin.pl/zabiegi/aparat-staly-metalowy",
    "bodyLocation": "Zęby",
    "procedureType": "Surgical",
    "provider": {
      "@type": "Dentist",
      "name": "ORTHOMEDICA — dr n. med. Kornelia Rumin",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ul. Pawia 67",
        "addressLocality": "Lubin",
        "postalCode": "59-300",
        "addressCountry": "PL"
      },
      "telephone": "+48694731124"
    }
  })} />
  <Header />

  <main class="pt-28 md:pt-32 pb-20 bg-white">
    <nav class="text-xs md:text-sm text-gray-400 mb-6 md:mb-8" aria-label="Okruszki nawigacyjne">
      <div class="container mx-auto px-6">
        <ol class="flex flex-wrap items-center gap-1 md:gap-2">
          <li><a href="/" class="hover:text-gold">Strona główna</a></li>
          <li class="text-gray-300">/</li>
          <li><span class="text-gray-400">Zabiegi</span></li>
          <li class="text-gray-300">/</li>
          <li><span class="text-navy">Aparat stały metalowy</span></li>
        </ol>
      </div>
    </nav>

    <section class="py-8 md:py-12">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
          <div>
            <h1 class="cinzel text-xs md:text-sm text-gold font-bold tracking-[0.5em] mb-4 uppercase">
              Zabieg ortodontyczny
            </h1>
            <h2 class="text-3xl md:text-4xl lg:text-5xl serif mb-4 md:mb-6 text-navy">
              Aparat stały metalowy Lubin
            </h2>
            <p class="text-[15px] md:text-base text-gray-600 font-light mb-6 md:mb-8 max-w-xl">
              Klasyczny aparat stały z metalowymi zamkami to sprawdzona metoda leczenia nawet złożonych wad zgryzu.
              Stosujemy nowoczesne systemy łuków i zamków, które pozwalają leczyć skutecznie i przewidywalnie.
            </p>
            <a href="/#kontakt" class="btn-gold inline-flex items-center gap-2 px-8 py-3 rounded-full text-xs font-bold uppercase tracking-[0.2em]">
              Umów konsultację
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
          </div>

          <div class="grid gap-4 md:gap-6">
            <div class="rounded-3xl overflow-hidden shadow-lg border border-gray-100">
              <img
                src="https://images.unsplash.com/photo-1608539735106-0c9f4bdca0ad?auto=format&fit=crop&q=80&w=1200"
                alt="Aparat stały metalowy na zębach"
                loading="lazy"
                class="w-full h-64 md:h-80 object-cover"
              />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100">
                <img
                  src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?auto=format&fit=crop&q=80&w=800"
                  alt="Widok aparatu stałego w gabinecie"
                  loading="lazy"
                  class="w-full h-32 md:h-40 object-cover"
                />
              </div>
              <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100">
                <img
                  src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&q=80&w=800"
                  alt="Ortodontka przygotowująca aparat stały"
                  loading="lazy"
                  class="w-full h-32 md:h-40 object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 md:py-14 bg-[#f8f7f4] border-y border-gray-100">
      <div class="container mx-auto px-6 max-w-4xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-6">Na czym polega leczenie aparatem stałym?</h3>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-4">
          Aparat stały składa się z zamków przyklejonych do zębów, łuków ortodontycznych oraz elementów dodatkowych,
          takich jak ligatury czy sprężyny. Odpowiednio dobrane siły działają na zęby przez całą dobę, stopniowo
          przesuwając je do docelowej pozycji.
        </p>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-4">
          Aparat metalowy jest rozwiązaniem uniwersalnym — pozwala skutecznie leczyć zarówno proste stłoczenia, jak
          i złożone wady wymagające szerszej kontroli nad ruchem zębów. To najczęściej wybierana forma leczenia u
          młodzieży, ale sprawdza się również u dorosłych pacjentów.
        </p>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-0">
          Kluczowe dla powodzenia terapii jest regularne zgłaszanie się na wizyty kontrolne co 6–8 tygodni, dbałość
          o higienę jamy ustnej oraz przestrzeganie zaleceń dotyczących diety i użytkowania aparatu.
        </p>
      </div>
    </section>

    <section class="py-10 md:py-14">
      <div class="container mx-auto px-6 max-w-4xl grid md:grid-cols-[1.3fr,1fr] gap-10 md:gap-12 items-start">
        <div>
          <h3 class="cinzel text-2xl md:text-3xl text-navy mb-4">Dla kogo jest aparat stały metalowy?</h3>
          <ul class="list-disc pl-5 space-y-2 text-[15px] md:text-base text-gray-600 font-light mb-4">
            <li>pacjentów z umiarkowanymi i ciężkimi stłoczeniami zębów,</li>
            <li>osób z wadą zgryzu wymagającą kontroli nachylenia i położenia pojedynczych zębów,</li>
            <li>młodzieży, u której aparat jest standardowym etapem leczenia ortodontycznego,</li>
            <li>dorosłych, u których Invisalign nie jest z różnych względów optymalnym wyborem.</li>
          </ul>
          <p class="text-[15px] md:text-base text-gray-600 font-light">
            Na konsultacji przedstawimy Ci różne możliwości leczenia (aparat metalowy, ceramiczny, nakładki)
            i wspólnie wybierzemy rozwiązanie najlepiej dopasowane do Twojej wady zgryzu, trybu życia i oczekiwań
            estetycznych.
          </p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
          <h4 class="cinzel text-lg text-navy mb-4">Leczenie krok po kroku</h4>
          <ol class="space-y-3 text-[15px] text-gray-600 font-light">
            <li><span class="font-semibold text-navy">1. Konsultacja</span> — badanie, omówienie oczekiwań, wstępny plan.</li>
            <li><span class="font-semibold text-navy">2. Diagnostyka</span> — skan 3D, zdjęcia RTG, fotografie.</li>
            <li><span class="font-semibold text-navy">3. Założenie aparatu</span> — przyklejenie zamków i założenie łuku.</li>
            <li><span class="font-semibold text-navy">4. Wizyty kontrolne</span> — co 6–8 tygodni regulacja aparatu.</li>
            <li><span class="font-semibold text-navy">5. Zdjęcie aparatu i retencja</span> — polerowanie zębów, retainery stałe lub szyny.</li>
          </ol>
        </div>
      </div>
    </section>

    <section class="py-10 md:py-14 bg-gray-50 border-y border-gray-100">
      <div class="container mx-auto px-6 max-w-4xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-6">Mini FAQ — aparat stały metalowy</h3>
        <div class="space-y-4">
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm open:border-gold transition-all">
            <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none">
              <span class="text-sm font-semibold text-navy">Czy zakładanie aparatu jest bolesne?</span>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 pt-1 text-[15px] text-gray-600 font-light">
              Samo przyklejanie zamków jest bezbolesne i nie wymaga znieczulenia. Przez kilka dni po założeniu aparatu
              możesz odczuwać tkliwość zębów — to naturalna reakcja na działanie sił przesuwających zęby.
            </div>
          </details>

          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm open:border-gold transition-all">
            <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none">
              <span class="text-sm font-semibold text-navy">Jakich produktów należy unikać w trakcie leczenia?</span>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 pt-1 text-[15px] text-gray-600 font-light">
              Unikaj twardych pokarmów nagryzanych zębami przednimi (np. jabłka w całości), bardzo lepkich słodyczy
              (krówki, ciągnące karmelki) oraz napojów gazowanych. Wszystko po to, aby nie uszkodzić zamków i chronić szkliwo.
            </div>
          </details>

          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm open:border-gold transition-all">
            <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none">
              <span class="text-sm font-semibold text-navy">Jak długo trwa leczenie aparatem stałym?</span>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 pt-1 text-[15px] text-gray-600 font-light">
              Średni czas leczenia wynosi 18–24 miesiące, ale zależy od rodzaju i nasilenia wady, wieku pacjenta oraz
              systematyczności wizyt kontrolnych.
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-16">
      <div class="container mx-auto px-6 text-center max-w-2xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-4">Porozmawiajmy o Twoim leczeniu</h3>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-6">
          Podczas konsultacji w ORTHOMEDICA przedstawimy Ci różne możliwości leczenia — w tym aparat metalowy,
          ceramiczny i nakładki Invisalign — oraz omówimy przewidywany czas terapii.
        </p>
        <a href="/#kontakt" class="btn-gold inline-flex items-center gap-2 px-10 py-4 rounded-full text-xs font-bold uppercase tracking-[0.2em]">
          Umów konsultację
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

