---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/footer.astro';
---

<Layout
  title="Retencja ortodontyczna Lubin — utrzymanie efektów leczenia | ORTHOMEDICA"
  description="Retencja po leczeniu ortodontycznym w Lubinie — retainery stałe i szyny retencyjne. Zadbaj o trwały efekt prostych zębów w ORTHOMEDICA."
  canonical="https://www.orthomedica.lubin.pl/zabiegi/retencja-ortodontyczna"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalProcedure",
    "name": "Retencja ortodontyczna",
    "url": "https://www.orthomedica.lubin.pl/zabiegi/retencja-ortodontyczna",
    "bodyLocation": "Zęby",
    "procedureType": "NonSurgical",
    "provider": {
      "@type": "Dentist",
      "name": "ORTHOMEDICA — dr n. med. Kornelia Rumin",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ul. Pawia 67",
        "addressLocality": "Lubin",
        "postalCode": "59-300",
        "addressCountry": "PL"
      },
      "telephone": "+48694731124"
    }
  })} />
  <Header />

  <main class="pt-28 md:pt-32 pb-20 bg-white">
    <nav class="text-xs md:text-sm text-gray-400 mb-6 md:mb-8" aria-label="Okruszki nawigacyjne">
      <div class="container mx-auto px-6">
        <ol class="flex flex-wrap items-center gap-1 md:gap-2">
          <li><a href="/" class="hover:text-gold">Strona główna</a></li>
          <li class="text-gray-300">/</li>
          <li><span class="text-gray-400">Zabiegi</span></li>
          <li class="text-gray-300">/</li>
          <li><span class="text-navy">Retencja ortodontyczna</span></li>
        </ol>
      </div>
    </nav>

    <section class="py-8 md:py-12">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
          <div>
            <h1 class="cinzel text-xs md:text-sm text-gold font-bold tracking-[0.5em] mb-4 uppercase">
              Ostatni etap leczenia
            </h1>
            <h2 class="text-3xl md:text-4xl lg:text-5xl serif mb-4 md:mb-6 text-navy">
              Retencja po leczeniu ortodontycznym
            </h2>
            <p class="text-[15px] md:text-base text-gray-600 font-light mb-6 md:mb-8 max-w-xl">
              Retencja to etap, w którym utrwalamy efekt prostych zębów po zdjęciu aparatu lub zakończeniu leczenia
              nakładkami. Bez niej zęby mają tendencję do częściowego powrotu na dawne pozycje.
            </p>
            <a href="/#kontakt" class="btn-gold inline-flex items-center gap-2 px-8 py-3 rounded-full text-xs font-bold uppercase tracking-[0.2em]">
              Umów wizytę retencyjną
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
          </div>

          <div class="grid gap-4 md:gap-6">
            <div class="rounded-3xl overflow-hidden shadow-lg border border-gray-100">
              <img
                src="https://images.unsplash.com/photo-1606811971618-4486d14f3f99?auto=format&fit=crop&q=80&w=1200"
                alt="Retainer po zdjęciu aparatu"
                loading="lazy"
                class="w-full h-64 md:h-80 object-cover"
              />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100">
                <img
                  src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&q=80&w=800"
                  alt="Szyna retencyjna na modelu zębów"
                  loading="lazy"
                  class="w-full h-32 md:h-40 object-cover"
                />
              </div>
              <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100">
                <img
                  src="https://images.unsplash.com/photo-1629904869392-ae2a682d4d01?auto=format&fit=crop&q=80&w=800"
                  alt="Kontrola retencji w gabinecie"
                  loading="lazy"
                  class="w-full h-32 md:h-40 object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 md:py-14 bg-[#f8f7f4] border-y border-gray-100">
      <div class="container mx-auto px-6 max-w-4xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-6">Jakie są formy retencji?</h3>
        <ul class="list-disc pl-5 space-y-2 text-[15px] md:text-base text-gray-600 font-light mb-4">
          <li>szyny retencyjne (zdejmowane) — przezroczyste nakładki noszone głównie w nocy,</li>
          <li>retainery stałe — cienki drucik przyklejony od wewnętrznej strony zębów przednich,</li>
          <li>kombinacja obu rozwiązań w zależności od rodzaju wady i ryzyka nawrotu.</li>
        </ul>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-0">
          O wyborze konkretnej formy retencji decyduje lekarz, biorąc pod uwagę przebieg leczenia, stabilność efektu
          oraz indywidualne uwarunkowania pacjenta.
        </p>
      </div>
    </section>

    <section class="py-10 md:py-14">
      <div class="container mx-auto px-6 max-w-4xl grid md:grid-cols-[1.3fr,1fr] gap-10 md:gap-12 items-start">
        <div>
          <h3 class="cinzel text-2xl md:text-3xl text-navy mb-4">Jak długo trwa retencja?</h3>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-4">
            Retencja to proces długoterminowy. Na pełną przebudowę kości i tkanek utrzymujących zęby potrzeba
            co najmniej kilkunastu miesięcy, dlatego przez pierwsze 1–2 lata retencja jest szczególnie ważna.
          </p>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-0">
            Retainer stały najczęściej zalecany jest do noszenia bezterminowo — tak długo, jak długo pacjent chce
            cieszyć się prostymi zębami. Szyny zdejmowane nosi się z czasem coraz rzadziej, według indywidualnych
            zaleceń lekarza.
          </p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
          <h4 class="cinzel text-lg text-navy mb-4">Jak dbać o retainery?</h4>
          <ul class="space-y-2 text-[15px] text-gray-600 font-light">
            <li>czyść szyny miękką szczoteczką i łagodnym środkiem myjącym,</li>
            <li>nie myj ich w gorącej wodzie (ryzyko odkształcenia),</li>
            <li>retainer stały dokładnie doczyszczaj nitką lub irygatorem,</li>
            <li>zgłoś się do kontroli, jeśli zauważysz odklejenie drucika lub pęknięcie szyny.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="py-10 md:py-14 bg-gray-50 border-y border-gray-100">
      <div class="container mx-auto px-6 max-w-4xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-6">Mini FAQ — retencja</h3>
        <div class="space-y-4">
          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm open:border-gold transition-all">
            <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none">
              <span class="text-sm font-semibold text-navy">Czy zęby zawsze wracają po zakończeniu leczenia?</span>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 pt-1 text-[15px] text-gray-600 font-light">
              Zęby mają naturalną tendencję do niewielkich przesunięć przez całe życie. Odpowiednio prowadzona
              retencja znacząco zmniejsza ryzyko zauważalnego nawrotu wady.
            </div>
          </details>

          <details class="group bg-white rounded-2xl border border-gray-100 shadow-sm open:border-gold transition-all">
            <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none">
              <span class="text-sm font-semibold text-navy">Co jeśli zignoruję etap retencji?</span>
              <i data-lucide="plus" class="text-gold w-5 h-5 transition-transform group-open:rotate-45 shrink-0"></i>
            </summary>
            <div class="px-5 pb-4 pt-1 text-[15px] text-gray-600 font-light">
              Brak retencji zwiększa ryzyko, że zęby częściowo wrócą w poprzednie położenia. W skrajnych przypadkach
              może być konieczne ponowne leczenie ortodontyczne.
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-16">
      <div class="container mx-auto px-6 text-center max-w-2xl">
        <h3 class="cinzel text-2xl md:text-3xl text-navy mb-4">Zabezpiecz efekt leczenia</h3>
        <p class="text-[15px] md:text-base text-gray-600 font-light mb-6">
          Jeśli zakończyłeś leczenie ortodontyczne lub planujesz zdjąć aparat, zaplanuj wizytę retencyjną w
          ORTHOMEDICA. Dobierzemy indywidualnie dopasowaną formę utrzymania efektu.
        </p>
        <a href="/#kontakt" class="btn-gold inline-flex items-center gap-2 px-10 py-4 rounded-full text-xs font-bold uppercase tracking-[0.2em]">
          Umów wizytę retencyjną
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

