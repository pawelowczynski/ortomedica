---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import type { MarkdownInstance } from 'astro';

type BlogFrontmatter = {
  title: string;
  description: string;
  date: string;
  author?: string;
  tags?: string[];
  heroImage?: string;
  canonical?: string;
};

type BlogPost = MarkdownInstance<BlogFrontmatter>;

const posts = Object.values(
  import.meta.glob<MarkdownInstance<BlogFrontmatter>>('../../content/blog/*.md', {
    eager: true,
  }),
) as BlogPost[];

const sortedPosts = posts
  .map((post) => ({
    ...post,
    frontmatter: {
      ...post.frontmatter,
      date: post.frontmatter.date ?? new Date().toISOString(),
    },
  }))
  .sort((a: BlogPost, b: BlogPost) => {
    return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
  });

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  'name': 'Blog ortodontyczny ORTHOMEDICA – porady i wiedza',
  'description':
    'Blog ortodontyczny gabinetu ORTHOMEDICA w Lubinie. Porady o aparatach stałych, Invisalign, leczeniu dzieci i dorosłych oraz higienie jamy ustnej.',
  'url': 'https://www.orthomedica.lubin.pl/blog',
  'mainEntity': {
    '@type': 'ItemList',
    'itemListElement': sortedPosts.map((post: BlogPost, index: number) => ({
      '@type': 'ListItem',
      'position': index + 1,
      'url': `https://www.orthomedica.lubin.pl/blog/${post.file
        .split('/')
        .pop()
        ?.replace('.md', '')}`,
      'name': post.frontmatter.title,
    })),
  },
};
---

<Layout
  title="Blog ortodontyczny ORTHOMEDICA – porady specjalisty z Lubina"
  description="Poznaj praktyczne porady ortodontyczne od dr n. med. Kornelii Rumin. Blog ORTHOMEDICA o aparatach stałych, Invisalign i leczeniu dzieci oraz dorosłych w Lubinie."
  canonical="https://www.orthomedica.lubin.pl/blog"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Header />

  <main class="min-h-screen bg-surface-warm pb-20 pt-28 md:pt-32">
    <section class="py-12 md:py-16">
      <div class="container mx-auto px-6">
        <div class="mb-10 max-w-3xl md:mb-14">
          <p class="cinzel mb-3 text-[11px] font-bold uppercase italic tracking-[0.5em] text-gold md:text-xs">
            Wiedza &amp; Porady
          </p>
          <h1 class="serif mb-4 text-3xl text-brand-steel md:text-4xl lg:text-5xl">
            Blog ortodontyczny ORTHOMEDICA
          </h1>
          <p class="text-sm leading-relaxed text-brand-steel/75 md:text-base">
            Tutaj znajdziesz praktyczne wskazówki dotyczące leczenia ortodontycznego, aparatów stałych i przezroczystych nakładek,
            a także poradnikowe treści dla rodziców i pacjentów z Lubina i okolic.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {sortedPosts.map((post: BlogPost) => {
            const slug = post.file.split('/').pop()?.replace('.md', '') ?? '';
            return (
              <BlogCard
                title={post.frontmatter.title}
                description={post.frontmatter.description}
                date={post.frontmatter.date}
                slug={slug}
                tags={post.frontmatter.tags}
                heroImage={post.frontmatter.heroImage}
              />
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

