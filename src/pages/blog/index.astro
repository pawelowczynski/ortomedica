---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import type { MarkdownInstance } from 'astro';

type BlogFrontmatter = {
  title: string;
  description: string;
  date: string;
  author?: string;
  tags?: string[];
  heroImage?: string;
  canonical?: string;
};

type BlogPost = MarkdownInstance<BlogFrontmatter>;

// @ts-ignore Astro.glob is provided by Astro at build time
const posts = await (Astro as any).glob<BlogFrontmatter>('../../content/blog/*.md');

const sortedPosts = (posts as BlogPost[])
  .map((post) => ({
    ...post,
    frontmatter: {
      ...post.frontmatter,
      date: post.frontmatter.date ?? new Date().toISOString(),
    },
  }))
  .sort((a: BlogPost, b: BlogPost) => {
    return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
  });

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  'name': 'Blog ortodontyczny ORTHOMEDICA – porady i wiedza',
  'description':
    'Blog ortodontyczny kliniki ORTHOMEDICA w Lubinie. Porady dotyczące aparatów stałych, Invisalign, leczenia dzieci i dorosłych oraz higieny jamy ustnej.',
  'url': 'https://orthomedica-lubin.pl/blog',
  'mainEntity': {
    '@type': 'ItemList',
    'itemListElement': sortedPosts.map((post: BlogPost, index: number) => ({
      '@type': 'ListItem',
      'position': index + 1,
      'url': `https://orthomedica-lubin.pl/blog/${post.file
        .split('/')
        .pop()
        ?.replace('.md', '')}`,
      'name': post.frontmatter.title,
    })),
  },
};
---

<Layout
  title="Blog ortodontyczny ORTHOMEDICA – porady specjalisty z Lubina"
  description="Poznaj praktyczne porady ortodontyczne od dr n. med. Kornelii Rumin. Blog ORTHOMEDICA o aparatach stałych, Invisalign i leczeniu dzieci oraz dorosłych w Lubinie."
  canonical="https://orthomedica-lubin.pl/blog"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Header />

  <main class="pt-28 md:pt-32 pb-20 bg-navy-light min-h-screen">
    <section class="py-12 md:py-16">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl mb-10 md:mb-14">
          <p class="cinzel text-[11px] md:text-xs text-gold font-bold tracking-[0.5em] mb-3 uppercase italic">
            Wiedza &amp; Porady
          </p>
          <h1 class="text-3xl md:text-4xl lg:text-5xl serif text-white mb-4">
            Blog ortodontyczny ORTHOMEDICA
          </h1>
          <p class="text-sm md:text-base text-white/70 leading-relaxed">
            Tutaj znajdziesz praktyczne wskazówki dotyczące leczenia ortodontycznego, aparatów stałych i przezroczystych nakładek,
            a także poradnikowe treści dla rodziców i pacjentów z Lubina i okolic.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {sortedPosts.map((post: BlogPost) => {
            const slug = post.file.split('/').pop()?.replace('.md', '') ?? '';
            return (
              <BlogCard
                title={post.frontmatter.title}
                description={post.frontmatter.description}
                date={post.frontmatter.date}
                slug={slug}
                tags={post.frontmatter.tags}
                heroImage={post.frontmatter.heroImage}
              />
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

